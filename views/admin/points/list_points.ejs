<%- include("../components/header") %>
<%- include("../components/menu", { eventId: eventId }) %>
<link rel="stylesheet" href="/admin/assets/css/style.css">

<div id="right-panel" class="right-panel">
    <%- include("../components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('points_pages.listHeading') %></strong>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th><%= t('points_pages.colId') %></th>
                                        <th><%= t('points_pages.colPoints') %></th>
                                        <th><%= t('points_pages.colCreatedAt') %></th>
                                        <th><%= t('points_pages.colActions') %></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% points.forEach(point => { %>
                                        <tr>
                                            <td><%= point._id %></td>
                                            <td><%= point.point %></td>
                                            <td><%= point.created_at.toISOString().slice(0, 10) %></td>
                                            <td>
                                                <a href="/events/<%= eventId %>/points/edit/<%= point._id %>" class="btn btn-warning btn-sm"><%= t('points_pages.editBtn') %></a>
                                                <a href="/events/<%= eventId %>/points/<%= point._id %>" class="btn btn-info btn-sm"><%= t('points_pages.viewQrBtn') %></a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("../components/footer") %>
