<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'zh-Hant' %>">
<head>
    <meta charset="UTF-8">
    <title><%= t('points_pages.qrcodeTitle') %></title>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.qrcode/1.0/jquery.qrcode.min.js"></script>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: rgb(0, 46, 93);
            color: white;
            font-family: Arial, sans-serif;
        }
        #qrcode {
            text-align: center;
        }
        img {
            max-width: 300px;
            height: auto;
        }
    </style>
</head>
<body>

    <div id="qrcode">
        <h1><%= t('points_pages.qrcodeHeading') %></h1>
        <div id="qrcodeImage"></div>
    </div>

    <script>
        $(document).ready(function() {
            const qrCodeData = "<%= eventId %>,<%= pointId %>";
            $('#qrcodeImage').qrcode({
                text: qrCodeData,
                width: 256,
                height: 256
            });
        });
    </script>

</body>
</html>
