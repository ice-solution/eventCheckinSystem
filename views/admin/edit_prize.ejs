<%- include ("components/header") %>
<%- include ("components/menu", {eventId: eventId }) %>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">
<div id="right-panel" class="right-panel">
    <%- include ("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('edit_prize.title') %> - <%= event.name %></strong>
                        </div>
                        <div class="card-body">
                            <form id="editPrizeForm">
                                <div class="form-group">
                                    <label for="name"><%= t('edit_prize.prizeName') %></label>
                                    <input type="text" class="form-control" id="name" name="name" value="<%= prize.name %>" required>
                                </div>
                                <div class="form-group">
                                    <label for="prizeImage"><%= t('edit_prize.prizeImage') %></label>
                                    <input type="file" class="form-control-file" id="prizeImage" name="prizeImage" accept="image/*">
                                    <small class="form-text text-muted"><%= t('edit_prize.imageSupport') %></small>
                                    <% if (prize.picture) { %>
                                        <div class="mt-2">
                                            <label><%= t('edit_prize.currentImage') %></label>
                                            <img src="<%= prize.picture %>" alt="<%= prize.name %>" style="max-width: 100px; max-height: 100px; display: block; margin-top: 5px;">
                                        </div>
                                    <% } %>
                                </div>
                                <div class="form-group">
                                    <label for="picture"><%= t('edit_prize.imageUrl') %></label>
                                    <input type="text" class="form-control" id="picture" name="picture" value="<%= prize.picture || '' %>" placeholder="https://example.com/image.jpg">
                                    <small class="form-text text-muted"><%= t('edit_prize.imageUrlNote') %></small>
                                </div>
                                <div class="form-group">
                                    <label for="unit"><%= t('edit_prize.quantity') %></label>
                                    <input type="number" class="form-control" id="unit" name="unit" value="<%= prize.unit %>" min="0" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><%= t('edit_prize.updateBtn') %></button>
                                <a href="/prizes/<%= eventId %>/prizes/list" class="btn btn-secondary"><%= t('edit_prize.backToList') %></a>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include ("./components/footer") %>
<script>
    $(document).ready(function() {
        $('#editPrizeForm').on('submit', function(e) {
            e.preventDefault();
            const formData = new FormData();
            formData.append('name', $('#name').val());
            formData.append('unit', $('#unit').val());
            const imageFile = $('#prizeImage')[0].files[0];
            if (imageFile) formData.append('prizeImage', imageFile);
            else formData.append('picture', $('#picture').val());
            fetch(`/prizes/<%= eventId %>/prizes/<%= prize._id %>`, { method: 'PUT', body: formData })
            .then(r => r.json())
            .then(data => {
                if (data._id) { alert(t('edit_prize.updateSuccess')); window.location.href = `/prizes/<%= eventId %>/prizes/list`; }
                else alert(t('edit_prize.updateFailed') + (data.message || ''));
            })
            .catch(() => alert(t('edit_prize.updateFailed')));
        });
    });
</script>
