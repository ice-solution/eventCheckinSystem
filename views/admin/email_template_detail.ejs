<script type="text/javascript">
    $(document).ready(function () {
        $('#email-records-data-table').DataTable({
            "order": [[0, "desc"]],
            "columnDefs": [
                { "type": "date", "targets": 0 }
            ],
            "pageLength": 10,
            "lengthMenu": [5, 10, 25, 50],
        });

    });
</script>
