<%- include ("components/header") %>
<%- include ("components/menu", {eventId: eventId || ''})  %>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/lib/datatable/dataTables.bootstrap.min.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">
    <% const tinyMceApiKey = typeof TINYMCE_API_KEY !== 'undefined' ? TINYMCE_API_KEY : '0o0ixrpieipnq3fsu3kbsdu9e627qg468y6lpup3gmhx8lz7'; %>
    <script src="https://cdn.tiny.cloud/1/<%= tinyMceApiKey %>/tinymce/7/tinymce.min.js"
        referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '#content',
            plugins: 'image code link',
            toolbar: 'undo redo | fontselect | styleselect | bold italic | alignleft aligncenter alignright | image link | code',
            font_formats: '標楷體=DFKai-SB,BiauKai,AR PL UKai TW;微軟正黑體=Microsoft JhengHei,微軟正黑體;新細明體=PMingLiU,新細明體;細明體=MingLiU,細明體;Arial=arial,helvetica,sans-serif;Comic Sans MS=comic sans ms,sans-serif;Courier New=courier new,courier;Georgia=georgia,palatino;Helvetica=helvetica;Impact=impact,chicago;Symbol=symbol;Tahoma=tahoma,arial,helvetica,sans-serif;Terminal=terminal,monaco;Times New Roman=times new roman,times;Trebuchet MS=trebuchet ms,geneva;Verdana=verdana,geneva;Webdings=webdings;Wingdings=wingdings,zapf dingbats',
            font_family_formats: '標楷體=DFKai-SB,BiauKai,AR PL UKai TW;微軟正黑體=Microsoft JhengHei,微軟正黑體;新細明體=PMingLiU,新細明體;細明體=MingLiU,細明體;Arial=arial,helvetica,sans-serif;Comic Sans MS=comic sans ms,sans-serif;Courier New=courier new,courier;Georgia=georgia,palatino;Helvetica=helvetica;Impact=impact,chicago;Symbol=symbol;Tahoma=tahoma,arial,helvetica,sans-serif;Terminal=terminal,monaco;Times New Roman=times new roman,times;Trebuchet MS=trebuchet ms,geneva;Verdana=verdana,geneva;Webdings=webdings;Wingdings=wingdings,zapf dingbats',
            content_css: '/admin/assets/css/tinymce-custom-fonts.css',
            content_style: 'body { font-family: Arial, sans-serif; } * { font-family: inherit; }',
            images_upload_url: '/emailTemplate/upload',
            automatic_uploads: true,
            convert_urls: true,
            relative_urls: false,
            remove_script_host: false,
            document_base_url: window.location.origin,
            file_picker_types: 'image',
            file_picker_callback: function (callback, value, meta) {
                if (meta.filetype === 'image') {
                    var input = document.createElement('input');
                    input.setAttribute('type', 'file');
                    input.setAttribute('accept', 'image/*');
                    input.onchange = function () {
                        var file = this.files[0];
                        var reader = new FileReader();
                        reader.onload = function () {
                            callback(reader.result, { alt: file.name });
                        };
                        reader.readAsDataURL(file);
                    };
                    input.click();
                }
            },
            image_advtab: true,
            image_dimensions: true,
            image_class_list: [
                {title: 'Responsive', value: 'img-fluid'}
            ],
            urlconverter_callback: function(url, node, on_save, name) {
                if (url && (url.includes('banner') || url.includes('exvent'))) {
                    if (url.indexOf('http') !== 0 && url.indexOf('//') !== 0) {
                        if (url.indexOf('/') === 0) {
                            return window.location.origin + url;
                        } else {
                            return window.location.origin + '/' + url;
                        }
                    }
                }
                return url;
            }
        });
    </script>
<div id="right-panel" class="right-panel">
    <%- include ("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('create_email_template.title') %></strong>
                        </div>
                        <div class="card-body">
        <form id="emailTemplateForm">
            <div class="form-group">
                <label for="subject"><%= t('create_email_template.subjectLabel') %></label>
                <input type="text" class="form-control" id="subject" value="<%= template.subject %>" required>
            </div>
            <div class="form-group">
                <label for="type"><%= t('create_email_template.typeLabel') %></label>
                <select class="form-control" id="type" required>
                    <option value="invitation" <%= template.type === 'invitation' ? 'selected' : '' %>><%= t('create_email_template.typeInvitation') %></option>
                    <option value="welcome" <%= template.type === 'welcome' ? 'selected' : '' %>><%= t('create_email_template.typeWelcome') %></option>
                    <option value="knowledge" <%= template.type === 'knowledge' ? 'selected' : '' %>><%= t('create_email_template.typeKnowledge') %></option>
                    <option value="reminder" <%= template.type === 'reminder' ? 'selected' : '' %>><%= t('create_email_template.typeReminder') %></option>
                    <option value="invoice" <%= template.type === 'invoice' ? 'selected' : '' %>><%= t('create_email_template.typeInvoice') %></option>
                    <option value="payment_receipt" <%= template.type === 'payment_receipt' ? 'selected' : '' %>><%= t('create_email_template.typePaymentReceipt') %></option>
                </select>
            </div>
            <div class="form-group">
                <label for="body"><%= t('create_email_template.contentLabel') %></label>
                <textarea class="form-control" name="content" id="content" rows="10">
                    <%= template.content %>
                </textarea>
            </div>
                            <button type="submit" class="btn btn-primary"><%= t('create_email_template.saveBtn') %></button>
                            <a href="/emailTemplate/preview/<%= template._id %>" class="btn btn-outline-info" target="_blank" rel="noopener">Preview HTML</a>
                            <small class="d-block text-muted mt-2">
                                <strong>網頁版郵件連結（請貼在模板 HTML，勿寫死 URL）：</strong>
                                <pre class="bg-light p-2 mt-1 mb-2" style="font-size:12px;white-space:pre-wrap;">&lt;center&gt;
If you cannot read this message, please &lt;a href="{{emailPreviewUrl}}" target="_blank"&gt;click here&lt;/a&gt;.
（亦可使用 {{contentUrl}} 或 {{webVersionUrl}}，內容相同）
&lt;/center&gt;</pre>
                                發信時會自動換成：<code>{DOMAIN}/emailTemplate/preview/本模板ID?userId=該用戶_id</code>
                                <br>後台預覽：<code>/emailTemplate/preview/<%= template._id %>?userId=用戶_id</code>
                                <% if (!eventId) { %><br>全域模板預覽請加 <code>&amp;eventId=活動_id</code><% } %>
                                <br>發票／付款信可加 <code>&amp;transactionId=Transaction_id</code>
                            </small>
                            <button type="button" class="btn btn-danger" onclick="deleteTemplate()"><%= t('create_email_template.deleteTemplateBtn') %></button>
                            <% if (eventId) { %>
                            <a href="/events/<%= eventId %>/emailTemplate" class="btn btn-secondary"><%= t('create_email_template.backToEventList') %></a>
                            <% } else { %>
                            <a href="/emailTemplate" class="btn btn-secondary"><%= t('common.backToAdmin') %></a>
                            <% } %>
                            </form>
                            <div id="alertContainer" class="mt-3"></div>

                            <hr>
                            <h5><%= t('create_email_template.sendEmailTitle') %></h5>
                            <form id="sendEmailForm">
                                <div class="form-group">
                                    <label for="recipient"><%= t('create_email_template.recipientsLabel') %></label>
                                    <textarea class="form-control" id="recipient" rows="3" placeholder="<%= t('create_email_template.recipientsPlaceholder') %>"></textarea>
                                </div>
                                <button type="submit" class="btn btn-success"><%= t('create_email_template.sendEmailBtn') %></button>
                            </form>
                        </div>
                    </div>

                    <% if (stats) { %>
                    <div class="card mt-3">
                        <div class="card-header">
                            <strong class="card-title"><%= t('create_email_template.statsTitle') %></strong>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="card bg-primary text-white">
                                        <div class="card-body">
                                            <h5><%= t('common.total') %></h5>
                                            <h3><%= stats.total %></h3>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card bg-success text-white">
                                        <div class="card-body">
                                            <h5><%= t('common.send') %></h5>
                                            <h3><%= stats.sent %></h3>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card bg-info text-white">
                                        <div class="card-body">
                                            <h5><%= t('create_email_template.statsOpened') %></h5>
                                            <h3><%= stats.opened %></h3>
                                            <small><%= t('create_email_template.statsOpenRate') %>: <%= stats.openRate %>%</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card bg-warning text-white">
                                        <div class="card-body">
                                            <h5><%= t('create_email_template.statsClicked') %></h5>
                                            <h3><%= stats.clicked %></h3>
                                            <small><%= t('create_email_template.statsClickRate') %>: <%= stats.clickRate %>%</small>
                                            <br>
                                            <small><%= t('create_email_template.statsClickToOpen') %>: <%= stats.clickToOpenRate %>%</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <div class="card mt-3">
                        <div class="card-header">
                            <strong class="card-title"><%= t('create_email_template.sendRecordsTitle') %></strong>
                        </div>
                        <div class="card-body">

                            <table id="email-records-data-table" class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th><%= t('email_records.colSendTime') %></th>
                                        <th><%= t('email_records.colRecipient') %></th>
                                        <th><%= t('common.status') %></th>
                                        <th><%= t('create_email_template.statsOpened') %></th>
                                        <th><%= t('create_email_template.statsClicked') %></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% emailRecords.forEach(function(record) { %>
                                        <tr>
                                            <td>
                                                <%= new Date(record.created_at).toLocaleString('zh-HK', {
                                                    timeZone: 'Asia/Hong_Kong',
                                                    year: 'numeric',
                                                    month: '2-digit',
                                                    day: '2-digit',
                                                    hour: '2-digit',
                                                    minute: '2-digit',
                                                    second: '2-digit',
                                                    hour12: false
                                                }) %>
                                            </td>
                                            <td>
                                                <%= record.recipient %>
                                            </td>
                                            <td>
                                                <span class="badge badge-<%= record.status === '成功' || record.status === 'sent' || record.status === 'delivered' ? 'success' : 'danger' %>">
                                                    <%= record.status %>
                                                </span>
                                            </td>
                                            <td>
                                                <% if (record.opened_at) { %>
                                                    <span class="badge badge-info">
                                                        ✓ <%= record.opened_count || 1 %> <%= t('email_records.timesUnit') %>
                                                    </span>
                                                    <br>
                                                    <small><%= new Date(record.opened_at).toLocaleString('zh-HK', {
                                                        timeZone: 'Asia/Hong_Kong',
                                                        year: 'numeric',
                                                        month: '2-digit',
                                                        day: '2-digit',
                                                        hour: '2-digit',
                                                        minute: '2-digit',
                                                        second: '2-digit',
                                                        hour12: false
                                                    }) %></small>
                                                <% } else { %>
                                                    <span class="badge badge-secondary"><%= t('email_records.notOpened') %></span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (record.clicked_at) { %>
                                                    <span class="badge badge-warning">
                                                        ✓ <%= record.clicked_count || 1 %> <%= t('email_records.timesUnit') %>
                                                    </span>
                                                    <br>
                                                    <small><%= new Date(record.clicked_at).toLocaleString('zh-HK', {
                                                        timeZone: 'Asia/Hong_Kong',
                                                        year: 'numeric',
                                                        month: '2-digit',
                                                        day: '2-digit',
                                                        hour: '2-digit',
                                                        minute: '2-digit',
                                                        second: '2-digit',
                                                        hour12: false
                                                    }) %></small>
                                                <% } else { %>
                                                    <span class="badge badge-secondary"><%= t('email_records.notClicked') %></span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include ("components/footer") %>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
const _ETD = {
    deleteConfirm: '<%= t("create_email_template.deleteTemplateConfirm") %>',
    deleteSuccess: '<%= t("create_email_template.deleteSuccess") %>',
    deleteFailed: '<%= t("create_email_template.deleteFailed") %>',
    saveSuccess: '<%= t("create_email_template.saveSuccess") %>',
    saveFailed: '<%= t("create_email_template.saveFailed") %>',
    sendSuccess: '<%= t("create_email_template.sendSuccess") %>',
    sendFailed: '<%= t("create_email_template.sendFailed") %>'
};

    function deleteTemplate() {
        if (confirm(_ETD.deleteConfirm)) {
            const deleteUrl = '<%= eventId %>'
                ? '/events/<%= eventId %>/emailTemplate/<%= template._id %>'
                : '/emailTemplate/<%= template._id %>';

            $.ajax({
                url: deleteUrl,
                type: 'DELETE',
                success: function(response) {
                    const alertHtml = `
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            ${_ETD.deleteSuccess}
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    `;
                    $('#alertContainer').append(alertHtml);
                    setTimeout(() => {
                        <% if (eventId) { %>
                        window.location.href = '/events/<%= eventId %>/emailTemplate';
                        <% } else { %>
                        window.location.href = '/emailTemplate';
                        <% } %>
                    }, 1500);
                },
                error: function(xhr, status, error) {
                    const alertHtml = `
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            ${_ETD.deleteFailed}
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    `;
                    $('#alertContainer').append(alertHtml);
                }
            });
        }
    }

    $(document).ready(function () {
            $('#emailTemplateForm').on('submit', function (e) {
                e.preventDefault();

                const emailTemplate = {
                    subject: $('#subject').val(),
                    type: $('#type').val(),
                    content: tinymce.get('content').getContent(),
                };

                const updateUrl = '<%= eventId %>'
                ? '/events/<%= eventId %>/emailTemplate/<%= template._id %>'
                : '/emailTemplate/<%= template._id %>';

            $.ajax({
                    url: updateUrl,
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify(emailTemplate),
                    success: function (response) {
                        const alertHtml = `
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                ${_ETD.saveSuccess}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        `;
                        $('#alertContainer').append(alertHtml);
                        setTimeout(() => {
                            $('.alert').alert('close');
                        }, 1500);
                        $('#emailTemplateForm')[0].reset();
                    },
                    error: function (xhr, status, error) {
                        const alertHtml = `
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                ${_ETD.saveFailed}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        `;
                        $('#alertContainer').append(alertHtml);
                    }
                }).done(function () {
                    location.reload();
                });
            });
        });

        $('#sendEmailForm').on('submit', function (e) {
            e.preventDefault();

            const emailData = {
                recipient: $('#recipient').val(),
                subject: $('#subject').val(),
                content: tinymce.get('content').getContent(),
            };

            const sendUrl = '<%= eventId %>'
                ? '/events/<%= eventId %>/emailTemplate/<%= template._id %>/send'
                : '/emailTemplate/<%= template._id %>/send';

            $.ajax({
                url: sendUrl,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(emailData),
                success: function (response) {
                    const alertHtml = `
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                ${_ETD.sendSuccess}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                    `;
                    $('#alertContainer').append(alertHtml);
                    setTimeout(() => {
                        $('.alert').alert('close');
                    }, 1500);
                    $('#sendEmailForm')[0].reset();
                },
                error: function (xhr, status, error) {
                    const alertHtml = `
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                ${_ETD.sendFailed}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                    `;
                    $('#alertContainer').append(alertHtml);
                }
            }).done(function () {
                location.reload();
            });
        });
    </script>

<script src="/admin/assets/js/lib/data-table/datatables.min.js"></script>
<script src="/admin/assets/js/lib/data-table/dataTables.bootstrap.min.js"></script>
<script src="/admin/assets/js/lib/data-table/dataTables.buttons.min.js"></script>
<script src="/admin/assets/js/lib/data-table/buttons.bootstrap.min.js"></script>
<script src="/admin/assets/js/lib/data-table/jszip.min.js"></script>
<script src="/admin/assets/js/lib/data-table/vfs_fonts.js"></script>
<script src="/admin/assets/js/lib/data-table/buttons.html5.min.js"></script>
<script src="/admin/assets/js/lib/data-table/buttons.print.min.js"></script>
<script src="/admin/assets/js/lib/data-table/buttons.colVis.min.js"></script>
