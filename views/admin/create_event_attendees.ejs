<%- include("components/header") %>
<%- include("components/menu", { eventId: eventId }) %>
<%- include("components/responsive_layout_style") %>
<link rel="stylesheet" href="/admin/assets/css/style.css">

<div id="right-panel" class="right-panel">
    <%- include("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('event_attendees.createHeading') %></strong>
                        </div>
                        <div class="card-body">
                            <form id="attendeeForm">
                                <input type="hidden" id="eventId" value="<%= eventId %>">

                                <div class="form-group">
                                    <label for="name"><%= t('common.name') %></label>
                                    <input type="text" class="form-control" id="name" placeholder="<%= t('event_attendees.namePlaceholder') %>" required>
                                </div>
                                <div class="form-group">
                                    <label for="location"><%= t('event_attendees.colLocation') %></label>
                                    <input type="text" class="form-control" id="location" placeholder="<%= t('event_attendees.locationPlaceholder') %>" required>
                                </div>
                                <div class="form-group">
                                    <label for="phone"><%= t('common.phone') %></label>
                                    <input type="text" class="form-control" id="phone" placeholder="<%= t('event_attendees.phonePlaceholder') %>" required>
                                </div>
                                <div class="form-group">
                                    <label for="email"><%= t('common.email') %></label>
                                    <input type="email" class="form-control" id="email" placeholder="<%= t('event_attendees.emailPlaceholder') %>" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><%= t('event_attendees.createBtn') %></button>
                            </form>
                            <div id="result" class="mt-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("components/footer") %>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        $('#attendeeForm').on('submit', function(e) {
            e.preventDefault();
            const eventId = $('#eventId').val();
            const name = $('#name').val();
            const location = $('#location').val();
            const phone = $('#phone').val();
            const email = $('#email').val();

            $.ajax({
                url: `/events/${eventId}/attendees`,
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ name, location, phone, email }),
                success: function(response) {
                    $('#result').html(`<div class="alert alert-success">${response.message}</div>`);
                    $('#attendeeForm')[0].reset();
                },
                error: function(xhr) {
                    $('#result').html(`<div class="alert alert-danger">${xhr.responseJSON.message}</div>`);
                }
            });
        });
    });
</script>
