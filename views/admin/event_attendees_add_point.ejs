<%- include("components/header") %>
<%- include("components/menu", { eventId: eventId }) %>
<link rel="stylesheet" href="/admin/assets/css/style.css">

<div id="right-panel" class="right-panel">
    <%- include("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('event_attendees.addPointHeading') %></strong>
                        </div>
                        <div class="card-body">
                            <form id="promoCodeForm">
                                <input type="hidden" id="eventId" value="<%= eventId %>">
                                <input type="hidden" id="attendeeId" value="<%= attendeeId %>">

                                <div class="form-group">
                                    <label for="code_name"><%= t('event_attendees.codeNameLabel') %></label>
                                    <input type="text" class="form-control" id="code_name" placeholder="<%= t('event_attendees.codeNamePlaceholder') %>" required>
                                </div>
                                <div class="form-group">
                                    <label for="point"><%= t('event_attendees.pointLabel') %></label>
                                    <input type="number" class="form-control" id="point" placeholder="<%= t('event_attendees.pointPlaceholder') %>" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><%= t('event_attendees.addPointBtn') %></button>
                            </form>
                            <div id="result" class="mt-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("components/footer") %>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        $('#promoCodeForm').on('submit', function(e) {
            e.preventDefault();
            const eventId = $('#eventId').val();
            const attendeeId = $('#attendeeId').val();
            const code_name = $('#code_name').val();
            const point = $('#point').val();

            $.ajax({
                url: `/events/${eventId}/attendees/${attendeeId}/promote`,
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ code_name, point }),
                success: function(response) {
                    $('#result').html(`<div class="alert alert-success">${response.message}</div>`);
                    $('#promoCodeForm')[0].reset();
                },
                error: function(xhr) {
                    $('#result').html(`<div class="alert alert-danger">${xhr.responseJSON.message}</div>`);
                }
            });
        });
    });
</script>
