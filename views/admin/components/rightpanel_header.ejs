<header id="header" class="header">
    <div class="top-right" style="width:100%; display:flex; align-items:center; justify-content:space-between;">
        <% if (typeof backUrl !== 'undefined' && backUrl) { %>
        <a href="<%= backUrl %>" class="btn btn-light btn-sm" style="display:inline-flex; align-items:center; gap:6px; margin-left:16px;">
            <i class="fa fa-arrow-left"></i> <%= lang === 'zh' ? '上一頁' : 'Back' %>
        </a>
        <% } else { %>
        <span></span>
        <% } %>
        <div class="header-menu">
            <div class="lang-switcher" style="display:inline-flex; align-items:center; margin-right:16px; gap:2px; background:#f1f5f9; border-radius:20px; padding:3px;">
                <a href="/set-lang?lang=zh"
                   style="text-decoration:none; line-height:1;"
                   class="btn btn-xs <%= lang === 'zh' ? 'btn-primary' : '' %>"
                   title="中文">
                    CN
                </a>
                <span style="color:#b0bec5; font-size:12px; font-weight:300;">/</span>
                <a href="/set-lang?lang=en"
                   style="text-decoration:none; line-height:1;"
                   class="btn btn-xs <%= lang === 'en' ? 'btn-primary' : '' %>"
                   title="English">
                    EN
                </a>
            </div>

            <div class="user-area dropdown float-right">

                <div class="user-menu dropdown-menu">
                    <a class="nav-link" href="/logout"><i class="fa fa-power-off"></i> <%= t('common.logout') %></a>
                </div>
            </div>
        </div>
    </div>
</header>

