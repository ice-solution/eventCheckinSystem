<style>
    /* ── 響應式容器：禁止整頁橫向捲動，內容隨左側欄收合平滑縮放 ── */
    html, body {
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        max-width: 100vw;
    }

    #right-panel {
        width: calc(100% - 280px);
        margin-left: 280px;
        box-sizing: border-box;
        transition: width 0.3s ease, margin-left 0.3s ease;
        overflow-x: hidden;
        max-width: calc(100vw - 280px);
    }

    body.open #right-panel {
        width: calc(100% - 83px);
        margin-left: 83px;
        max-width: calc(100vw - 83px);
    }

    #right-panel .content,
    #right-panel .animated {
        overflow-x: hidden;
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }

    .content {
        width: 100%;
        max-width: 100%;
        padding: 1.875em;
        box-sizing: border-box;
        overflow-x: hidden;
    }

    /* ── 通用 card header：title 與右側 action flex 對齊 ── */
    .card-header-with-action {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px !important;
    }

    /* ── 通用 DataTable 樣式（匹配 users 頁風格） ── */

    /* Table 字體、間距、分隔線 */
    .dataTables_wrapper table.dataTable thead th,
    .dataTables_wrapper table.dataTable tbody td {
        font-size: 13px;
        padding: 10px 14px !important;
        vertical-align: middle;
        border-bottom: 1px solid #eef1f5;
    }

    /* Header 背景、顏色、字重 */
    .dataTables_wrapper table.dataTable thead th {
        font-weight: 600;
        color: #334155;
        background: #f8fafc;
        border-bottom: 1px solid #e4e9f0 !important;
    }

    /* 排序三角：移除預設背景圖，改用 ▲▼ 字符 */
    .dataTables_wrapper table.dataTable thead th.sorting,
    .dataTables_wrapper table.dataTable thead th.sorting_asc,
    .dataTables_wrapper table.dataTable thead th.sorting_desc {
        background-image: none !important;
        position: relative;
        padding-right: 22px !important;
    }

    .dataTables_wrapper table.dataTable thead th.sorting::before,
    .dataTables_wrapper table.dataTable thead th.sorting_asc::before,
    .dataTables_wrapper table.dataTable thead th.sorting_desc::before {
        display: none !important;
    }

    .dataTables_wrapper table.dataTable thead th.sorting::after,
    .dataTables_wrapper table.dataTable thead th.sorting_asc::after,
    .dataTables_wrapper table.dataTable thead th.sorting_desc::after {
        position: absolute !important;
        right: 4px !important;
        top: 50% !important;
        transform: translateY(-50%) !important;
        display: block !important;
        margin: 0 !important;
        font-size: 9px !important;
        line-height: 1 !important;
        content: '▲▼' !important;
        color: #ccc !important;
        pointer-events: none;
    }

    .dataTables_wrapper table.dataTable thead th.sorting_asc::after {
        content: '▲' !important;
        color: #444 !important;
    }

    .dataTables_wrapper table.dataTable thead th.sorting_desc::after {
        content: '▼' !important;
        color: #444 !important;
    }

    /* DataTables info 文字 */
    .dataTables_wrapper .dataTables_info {
        padding: 14px 12px 6px !important;
        font-size: 13px !important;
        color: #64748b !important;
        white-space: normal !important;
    }

    /* Info 同 paginate 各自獨佔一行（覆蓋 Bootstrap col-md-5/7 分欄） */
    .dataTables_wrapper > .row:last-child > div[class*="col-"] {
        flex: 0 0 100% !important;
        max-width: 100% !important;
    }

    /* Info 靠左，paginate 置中 */
    .dataTables_wrapper > .row:last-child > div[class*="col-"]:has(.dataTables_info) {
        text-align: left !important;
    }

    .dataTables_wrapper > .row:last-child > div[class*="col-"]:has(.dataTables_paginate) {
        text-align: center !important;
    }

    /* 分頁：圓形、置中、teal active */
    .dataTables_wrapper .dataTables_paginate {
        padding: 4px 12px 10px !important;
        text-align: center !important;
    }

    .dataTables_wrapper .dataTables_paginate .pagination,
    .dataTables_wrapper .dataTables_paginate ul.pagination {
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        gap: 2px;
        margin: 0 !important;
    }

    .dataTables_wrapper .dataTables_paginate .page-link {
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        height: 32px !important;
        min-width: 32px !important;
        padding: 0 6px !important;
        border: none !important;
        border-radius: 50% !important;
        font-size: 14px !important;
        font-weight: 500 !important;
        color: #b0b8c1 !important;
        background: transparent !important;
        box-shadow: none !important;
        text-decoration: none !important;
    }

    .dataTables_wrapper .dataTables_paginate .page-link:hover {
        color: #555 !important;
        background: transparent !important;
    }

    .dataTables_wrapper .dataTables_paginate .page-item.active .page-link {
        color: #4DD0CA !important;
        font-weight: 700 !important;
        background: transparent !important;
    }

    /* 前一頁 / 下一頁：隱藏 "Previous"/"Next" 文字，改用 ‹ › 字符 */
    .dataTables_wrapper .dataTables_paginate .page-item.previous .page-link,
    .dataTables_wrapper .dataTables_paginate .page-item.next .page-link {
        font-size: 0 !important;
        width: 32px !important;
        min-width: 32px !important;
        height: 32px !important;
        padding: 0 !important;
        background: transparent !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        line-height: 1 !important;
    }

    .dataTables_wrapper .dataTables_paginate .page-item.previous .page-link::before {
        content: '‹';
        font-size: 22px;
        line-height: 0;
        color: #b0b8c1;
        display: block;
        transform: translateY(-3px);
    }

    .dataTables_wrapper .dataTables_paginate .page-item.next .page-link::after {
        content: '›';
        font-size: 22px;
        line-height: 0;
        color: #b0b8c1;
        display: block;
        transform: translateY(-4px);
    }

    .dataTables_wrapper .dataTables_paginate .page-item.previous:not(.disabled) .page-link::before,
    .dataTables_wrapper .dataTables_paginate .page-item.next:not(.disabled) .page-link::after {
        color: #555;
    }

    .dataTables_wrapper .dataTables_paginate .page-item.disabled .page-link {
        color: #d5d9dd !important;
        cursor: default !important;
    }

    .dataTables_wrapper .dataTables_paginate .page-item.disabled .page-link::before,
    .dataTables_wrapper .dataTables_paginate .page-item.disabled .page-link::after {
        color: #d5d9dd !important;
    }
</style>
