<aside id="left-panel" class="left-panel">
    <div class="sidebar-brand">
        <a href="/events/list" class="sidebar-brand-link">
            <img src="/admin/img/ba_logo.png" alt="Logo" class="sidebar-brand-logo" style="max-height:36px; object-fit:contain;">
            <span class="sidebar-brand-text">Brand Activation</span>
        </a>
        <a id="menuToggle" class="menutoggle sidebar-toggle" title="Collapse sidebar">
            <i class="fa fa-bars"></i>
        </a>
    </div>
    <div class="sidebar-collapsed-logo">
        <a href="/events/list">
            <img src="/admin/img/ba_logo.png" alt="Logo">
        </a>
    </div>
    <nav class="navbar navbar-expand-sm navbar-default">
        <div id="main-menu" class="main-menu collapse navbar-collapse">
            <ul class="nav navbar-nav">
                <% const user = typeof userForMenu !== 'undefined' ? userForMenu : null; %>
                <% const isAdmin = user && user.role === 'admin'; %>
                <% const allowedEvents = (user && user.allowedEvents) ? user.allowedEvents : []; %>
                <% const eventPerms = (user && eventId && user.eventPermissions) ? user.eventPermissions.find(p => (p.eventId && p.eventId.toString()) === (eventId && eventId.toString())) : null; %>
                <% const allowedFuncs = (eventPerms && eventPerms.functions) ? eventPerms.functions : []; %>
                <% const can = function(key) { return isAdmin || allowedFuncs.includes(key); }; %>
                <% const canAccessThisEvent = !eventId || isAdmin || (eventId && allowedEvents.some(function(id) { return id && id.toString() === (eventId && eventId.toString()); })); %>

                <% if (eventId && canAccessThisEvent) { %>
                <% if (can('rsvp')) { %>
                <li>
                    <a href="/events/<%=eventId%>" data-tooltip="<%= t('menu.rsvp') %>"> <i class="menu-icon fa fa-check-square-o"></i><%= t('menu.rsvp') %> </a>
                </li>
                <% } %>
                <li>
                    <a href="/events/<%=eventId%>/edit-name" data-tooltip="<%= t('menu.editEventName') %>"> <i class="menu-icon fa fa-edit"></i><%= t('menu.editEventName') %></a>
                </li>
                <% if (can('seating')) { %>
                <li>
                    <a href="/events/<%=eventId%>/seating-arrangement" data-tooltip="排桌 Seating"> <i class="menu-icon fa fa-th"></i>排桌 Seating</a>
                </li>
                <% } %>
                <%# HIDDEN: guestList — menu entry removed, route/function intact %>
                <% if (false && can('guestList')) { %>
                <li>
                    <a href="/events/<%=eventId%>/guest-list" data-tooltip="<%= t('menu.guestList') %>"> <i class="menu-icon fa fa-users"></i><%= t('menu.guestList') %> </a>
                </li>
                <% } %>
                <% if (can('emailTemplate')) { %>
                <li>
                    <a href="/events/<%=eventId%>/emailTemplate" data-tooltip="<%= t('menu.emailTemplate') %>"> <i class="menu-icon fa fa-envelope"></i><%= t('menu.emailTemplate') %> </a>
                </li>
                <% } %>
                <%# HIDDEN: smsTemplate — menu entry removed, route/function intact %>
                <% if (false && can('smsTemplate')) { %>
                <li>
                    <a href="/events/<%=eventId%>/smsTemplate" data-tooltip="<%= t('menu.smsTemplate') %>"> <i class="menu-icon fa fa-comment"></i><%= t('menu.smsTemplate') %> </a>
                </li>
                <% } %>
                <% if (can('badges')) { %>
                <li>
                    <a href="/events/<%=eventId%>/badges" data-tooltip="<%= t('menu.badgeDesign') %>"> <i class="menu-icon fa fa-id-card"></i><%= t('menu.badgeDesign') %> </a>
                </li>
                <% } %>
                <%# HIDDEN: qrcodeLogin — menu entry removed, route/function intact %>
                <% if (false && can('qrcodeLogin')) { %>
                <li>
                    <a href="/events/<%=eventId%>/qrcodeLogin" target="_blank" data-tooltip="<%= t('menu.qrcodeLogin') %>"> <i class="menu-icon fa fa-qrcode"></i><%= t('menu.qrcodeLogin') %></a>
                </li>
                <% } %>
                <%# HIDDEN: scanPointUsers — menu entry removed, route/function intact %>
                <% if (false && can('scanPointUsers')) { %>
                <li>
                    <a href="/events/<%=eventId%>/scan-point-users" data-tooltip="<%= t('menu.scanPoint') %>"> <i class="menu-icon fa fa-barcode"></i><%= t('menu.scanPoint') %></a>
                </li>
                <% } %>
                <%# HIDDEN: treasureHunt — menu entry removed, route/function intact %>
                <% if (false && can('treasureHunt')) { %>
                <li>
                    <a href="/events/<%=eventId%>/treasure-hunt" data-tooltip="<%= t('menu.treasureHunt') %>"> <i class="menu-icon fa fa-compass"></i><%= t('menu.treasureHunt') %></a>
                </li>
                <% } %>
                <% if (can('luckydrawList') || can('luckydrawPanel') || can('luckydrawAward') || can('luckydrawOpen') || can('luckydrawSetting') || can('prizes')) { %>
                <li class="menu-item-has-children dropdown">
                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" data-tooltip="<%= t('menu.luckyDraw') %>"> <i class="menu-icon fa fa-bar-chart"></i><%= t('menu.luckyDraw') %></a>
                    <ul class="sub-menu children dropdown-menu">
                        <% if (can('luckydrawOpen')) { %><li><i class="menu-icon fa fa-area-chart"></i><a target="_blank" href="/games/app/luckydraw_1/?id=<%= eventId %>"><%= t('menu.openLuckydraw') %></a></li><% } %>
                        <% if (can('luckydrawAward')) { %><li><i class="menu-icon fa fa-list-alt"></i><a target="_blank" href="/events/<%=eventId%>/luckydraw/award"><%= t('menu.awardList') %></a></li><% } %>
                        <% if (can('luckydrawPanel')) { %><li><i class="menu-icon fa fa-tablet"></i><a href="/events/<%=eventId%>/luckydraw/panel"><%= t('menu.luckydrawPanel') %></a></li><% } %>
                        <% if (can('luckydrawList')) { %><li><i class="menu-icon fa fa-rotate-left"></i><a href="/events/<%=eventId%>/luckydraw/list"><%= t('menu.luckydrawList') %></a></li><% } %>
                        <% if (can('prizes')) { %><li><i class="menu-icon fa fa-gift"></i><a href="/prizes/<%=eventId%>/prizes/list"><%= t('menu.prizeManagement') %></a></li><% } %>
                        <% if (can('luckydrawSetting')) { %><li><i class="menu-icon fa fa-cog"></i><a href="/events/<%=eventId%>/luckydraw_setting"><%= t('menu.luckydrawSetting') %></a></li><% } %>
                        <% if (can('luckydrawSetting')) { %><li><i class="menu-icon fa fa-cog"></i><a href="/events/<%=eventId%>/luckydraw-config/edit"><%= t('menu.gameConfig') %></a></li><% } %>
                    </ul>
                </li>
                <% } %>
                <% if (can('votes')) { %>
                <li>
                    <a href="/votes/<%=eventId%>/admin" data-tooltip="<%= t('menu.voteManagement') %>"> <i class="menu-icon fa fa-check-square-o"></i><%= t('menu.voteManagement') %></a>
                </li>
                <% } %>
                <% if (can('website') || can('formConfig')) { %>
                <li class="menu-item-has-children dropdown">
                    <a href="#" class="dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" data-tooltip="<%= t('menu.websiteContent') %>"> <i class="menu-icon fa fa-globe"></i><%= t('menu.websiteContent') %></a>
                    <ul class="sub-menu children dropdown-menu">
                        <% if (can('website')) { %><li><i class="menu-icon fa fa-link"></i><a target="_blank" href="/web/<%=eventId%>"><%= t('menu.websiteLink') %></a></li><% } %>
                        <% if (can('rsvp')) { %><li><i class="menu-icon fa fa-sign-in"></i><a target="_blank" href="/events/<%=eventId%>/login"><%= t('menu.eventUserLogin') %></a></li><% } %>
                        <% if (can('website')) { %><li><i class="menu-icon fa fa-user-plus"></i><a target="_blank" href="/web/<%=eventId%>/register"><%= t('menu.registrationPage') %></a></li><% } %>
                        <% if (can('formConfig')) { %><li><i class="menu-icon fa fa-cog"></i><a href="/formConfig/<%=eventId%>"><%= t('menu.registrationConfig') %></a></li><% } %>
                    </ul>
                </li>
                <% } %>
                <% if (can('transactions')) { %>
                <li>
                    <a href="/events/<%=eventId%>/payment-settings" data-tooltip="<%= t('menu.paymentSettings') %>"> <i class="menu-icon fa fa-credit-card"></i><%= t('menu.paymentSettings') %></a>
                </li>
                <li>
                    <a href="/events/<%=eventId%>/transactions" data-tooltip="<%= t('menu.transactionRecord') %>"> <i class="menu-icon fa fa-list-alt"></i><%= t('menu.transactionRecord') %></a>
                </li>
                <% } %>
                <% if (can('attachments')) { %>
                <li>
                    <a href="/events/<%=eventId%>/attachments" data-tooltip="<%= t('menu.attachments') %>"> <i class="menu-icon fa fa-paperclip"></i><%= t('menu.attachments') %></a>
                </li>
                <% } %>
                <% } %>
            </ul>
        </div>
    </nav>
</aside>
