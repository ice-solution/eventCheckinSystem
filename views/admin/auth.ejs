<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'zh-Hant' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('auth_add_user.title') %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h1><%= t('auth_add_user.heading') %></h1>
        <form id="addUserForm">
            <div class="form-group">
                <label for="username"><%= t('auth_add_user.usernameLabel') %></label>
                <input type="text" class="form-control" id="username" required>
            </div>
            <div class="form-group">
                <label for="password"><%= t('auth_add_user.passwordLabel') %></label>
                <input type="password" class="form-control" id="password" required>
            </div>
            <div class="form-group">
                <label for="role"><%= t('auth_add_user.roleLabel') %></label>
                <select class="form-control" id="role" required>
                    <option value="user"><%= t('auth_add_user.roleUser') %></option>
                    <option value="admin"><%= t('auth_add_user.roleAdmin') %></option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary"><%= t('auth_add_user.addBtn') %></button>
            <a href="/admin" class="btn btn-secondary"><%= t('auth_add_user.backBtn') %></a>
        </form>
        <div id="alertContainer" class="mt-3"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
    const _AU = {
        addSuccess: '<%= t("auth_add_user.addSuccess") %>',
        addFailed: '<%= t("auth_add_user.addFailed") %>'
    };

        $(document).ready(function() {
            $('#addUserForm').on('submit', function(e) {
                e.preventDefault();

                const newUser = {
                    username: $('#username').val(),
                    password: $('#password').val(),
                    role: $('#role').val()
                };

                $.ajax({
                    url: '/auth/add',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(newUser),
                    success: function(response) {
                        const alertHtml = `
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                ${_AU.addSuccess}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        `;
                        $('#alertContainer').append(alertHtml);
                        setTimeout(() => {
                            $('.alert').alert('close');
                        }, 1500);
                        $('#addUserForm')[0].reset();
                    },
                    error: function(xhr, status, error) {
                        const alertHtml = `
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                ${_AU.addFailed}
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        `;
                        $('#alertContainer').append(alertHtml);
                    }
                });
            });
        });
    </script>

    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
