<%- include ("components/header") %>
<%- include ("components/menu", { eventId: typeof eventId !== 'undefined' ? eventId : '' }) %>
<% const tinyMceApiKey = typeof TINYMCE_API_KEY !== 'undefined' ? TINYMCE_API_KEY : '0o0ixrpieipnq3fsu3kbsdu9e627qg468y6lpup3gmhx8lz7'; %>
<script src="https://cdn.tiny.cloud/1/<%= tinyMceApiKey %>/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
<script>
    tinymce.init({
        selector: '#content',
        plugins: 'image code link',
        toolbar: 'undo redo | fontselect | styleselect | bold italic | alignleft aligncenter alignright | image link | code',
        font_formats: '標楷體=DFKai-SB,BiauKai,標楷體,AR PL UKai TW,STKaiti;微軟正黑體=Microsoft JhengHei,微軟正黑體;新細明體=PMingLiU,新細明體;細明體=MingLiU,細明體;Arial=arial,helvetica,sans-serif;Comic Sans MS=comic sans ms,sans-serif;Courier New=courier new,courier;Georgia=georgia,palatino;Helvetica=helvetica;Impact=impact,chicago;Symbol=symbol;Tahoma=tahoma,arial,helvetica,sans-serif;Terminal=terminal,monaco;Times New Roman=times new roman,times;Trebuchet MS=trebuchet ms,geneva;Verdana=verdana,geneva;Webdings=webdings;Wingdings=wingdings,zapf dingbats',
        font_family_formats: '標楷體=DFKai-SB,BiauKai,標楷體,AR PL UKai TW,STKaiti;微軟正黑體=Microsoft JhengHei,微軟正黑體;新細明體=PMingLiU,新細明體;細明體=MingLiU,細明體;Arial=arial,helvetica,sans-serif;Comic Sans MS=comic sans ms,sans-serif;Courier New=courier new,courier;Georgia=georgia,palatino;Helvetica=helvetica;Impact=impact,chicago;Symbol=symbol;Tahoma=tahoma,arial,helvetica,sans-serif;Terminal=terminal,monaco;Times New Roman=times new roman,times;Trebuchet MS=trebuchet ms,geneva;Verdana=verdana,geneva;Webdings=webdings;Wingdings=wingdings,zapf dingbats',
        content_css: '/admin/assets/css/tinymce-custom-fonts.css',
        content_style: 'body { font-family: Arial, sans-serif; }',
        images_upload_url: '/emailTemplate/upload',
        automatic_uploads: true,
        convert_urls: true,
        relative_urls: false,
        remove_script_host: false,
        document_base_url: window.location.origin,
        file_picker_types: 'image',
        file_picker_callback: function (callback, value, meta) {
            if (meta.filetype === 'image') {
                var input = document.createElement('input');
                input.setAttribute('type', 'file');
                input.setAttribute('accept', 'image/*');
                input.onchange = function () {
                    var file = this.files[0];
                    var reader = new FileReader();
                    reader.onload = function () { callback(reader.result, { alt: file.name }); };
                    reader.readAsDataURL(file);
                };
                input.click();
            }
        },
        image_advtab: true,
        image_dimensions: true,
        image_class_list: [{ title: 'Responsive', value: 'img-fluid' }],
        urlconverter_callback: function(url, node, on_save, name) {
            if (url && (url.includes('banner') || url.includes('exvent'))) {
                if (url.indexOf('http') !== 0 && url.indexOf('//') !== 0) {
                    if (url.indexOf('/') === 0) return window.location.origin + url;
                    else return window.location.origin + '/' + url;
                }
            }
            return url;
        }
    });
</script>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">
<div id="right-panel" class="right-panel">
    <%- include ("components/rightpanel_header", { backUrl: eventId ? '/events/' + eventId + '/emailTemplate' : '/emailTemplate' }) %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('create_email_template.title') %></strong>
                        </div>
                        <div class="card-body">
                            <form id="emailTemplateForm">
                                <div class="form-group">
                                    <label for="subject"><%= t('create_email_template.subjectLabel') %></label>
                                    <input type="text" class="form-control" id="subject" required>
                                </div>
                                <div class="form-group">
                                    <label for="type"><%= t('create_email_template.typeLabel') %></label>
                                    <select class="form-control" id="type" required>
                                        <option value="invitation"><%= t('create_email_template.typeInvitation') %></option>
                                        <option value="welcome"><%= t('create_email_template.typeWelcome') %></option>
                                        <option value="knowledge"><%= t('create_email_template.typeKnowledge') %></option>
                                        <option value="reminder"><%= t('create_email_template.typeReminder') %></option>
                                        <option value="invoice"><%= t('create_email_template.typeInvoice') %></option>
                                        <option value="payment_receipt"><%= t('create_email_template.typePaymentReceipt') %></option>
                                    </select>
                                    <small class="form-text text-muted" id="typeSeedHint"></small>
                                    <button type="button" class="btn btn-sm btn-outline-secondary mt-1" id="loadTypeSeedBtn"><%= t('create_email_template.loadTypeSeedBtn') %></button>
                                </div>
                                <div class="form-group">
                                    <label for="body"><%= t('create_email_template.contentLabel') %></label>
                                    <textarea class="form-control" name="content" id="content" rows="10">
                                        <%= sampleEmailTemplate %>
                                    </textarea>
                                </div>
                                <button type="submit" class="btn btn-primary"><%= t('create_email_template.saveBtn') %></button>
                            </form>
                            <div id="alertContainer" class="mt-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include ("components/footer") %>
<script>
(function($) {
    const seedUrl = <% if (eventId) { %>'/events/<%= eventId %>/emailTemplate/seed'<% } else { %>'/emailTemplate/seed'<% } %>;
    let contentDirty = false;

    function applySeedToForm(seed, silent) {
        if (!seed) return;
        if (!silent && contentDirty) {
            if (!confirm('<%= t("create_email_template.loadTypeSeedConfirm") %>')) return;
        }
        if (seed.subject) $('#subject').val(seed.subject);
        if (seed.content && tinymce.get('content')) {
            tinymce.get('content').setContent(seed.content);
        }
        const sourceLabel = {
            event: '<%= t("create_email_template.seedSourceEvent") %>',
            global: '<%= t("create_email_template.seedSourceGlobal") %>',
            builtin: '<%= t("create_email_template.seedSourceBuiltin") %>',
            sample: '<%= t("create_email_template.seedSourceSample") %>'
        }[seed.source] || '';
        $('#typeSeedHint').text(sourceLabel ? ('<%= t("create_email_template.seedLoadedFrom") %>'.replace('{source}', sourceLabel)) : '');
        contentDirty = false;
    }

    function loadSeedForType(type, silent) {
        if (!type) return;
        $.get(seedUrl, { type: type }, function(seed) {
            applySeedToForm(seed, silent);
        }).fail(function() {
            $('#typeSeedHint').text('');
        });
    }

    $('#loadTypeSeedBtn').on('click', function() {
        loadSeedForType($('#type').val(), false);
    });

    $('#type').on('change', function() {
        loadSeedForType($(this).val(), true);
    });

    setTimeout(function() {
        const ed = tinymce.get('content');
        if (ed) ed.on('change keyup', function() { contentDirty = true; });
        loadSeedForType($('#type').val(), true);
    }, 800);

    $('#emailTemplateForm').on('submit', function (e) {
        e.preventDefault();
        const emailTemplate = {
            subject: $('#subject').val(),
            type: $('#type').val(),
            content: tinymce.get('content').getContent(),
        };

        <% if (eventId) { %>
        const submitUrl = '/events/<%= eventId %>/emailTemplate';
        emailTemplate.eventId = '<%= eventId %>';
        <% } else { %>
        const submitUrl = '/emailTemplate/create';
        <% } %>
        $.ajax({
            url: submitUrl,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(emailTemplate),
            success: function () {
                const alertHtml = `<div class="alert alert-success alert-dismissible fade show" role="alert"><%= t("create_email_template.saveSuccess") %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>`;
                $('#alertContainer').html(alertHtml);
                setTimeout(() => {
                    <% if (eventId) { %>
                    window.location.href = '/events/<%= eventId %>/emailTemplate';
                    <% } else { %>
                    window.location.href = '/emailTemplate';
                    <% } %>
                }, 1500);
            },
            error: function () {
                const alertHtml = `<div class="alert alert-danger alert-dismissible fade show" role="alert"><%= t("create_email_template.saveFailed") %><button type="button" class="close" data-dismiss="alert"><span>&times;</span></button></div>`;
                $('#alertContainer').html(alertHtml);
            }
        });
    });
})(jQuery);
</script>
