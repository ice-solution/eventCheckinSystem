<%- include ("components/header") %>
<%- include ("components/menu", {eventId: eventId }) %>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/lib/datatable/dataTables.bootstrap.min.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">
<div id="right-panel" class="right-panel">
    <%- include ("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">

            <!-- Email Template List -->
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('email_template_list.title') %></strong>
                            <% if (eventId != null) { %>
                                <a href="/events/<%= eventId %>/emailTemplate/create" class="btn btn-sm btn-primary float-right"><i class="fa fa-plus"></i> <%= t('email_template_list.createBtn') %></a>
                            <% } else { %>
                                <a href="/emailTemplate/create" class="btn btn-sm btn-primary float-right"><i class="fa fa-plus"></i> <%= t('email_template_list.createBtn') %></a>
                            <% } %>
                        </div>
                        <div class="card-body">
                            <table id="bootstrap-data-table" class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th><%= t('common.subject') %></th>
                                        <th><%= t('common.type') %></th>
                                        <th><%= t('common.created_at') %></th>
                                        <th><%= t('common.updated_at') %></th>
                                        <th><%= t('common.actions') %></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% emailTemplates.forEach(tmpl => { %>
                                        <tr>
                                            <td>
                                                <% if (tmpl.eventId) { %>
                                                    <a href="/events/<%= tmpl.eventId %>/emailTemplate/<%= tmpl._id %>" class="tmpl-open-link"><%= tmpl.subject %></a>
                                                <% } else { %>
                                                    <a href="/emailTemplate/<%= tmpl._id %>" class="tmpl-open-link"><%= tmpl.subject %></a>
                                                <% } %>
                                            </td>
                                            <td><%= tmpl.type || 'welcome' %></td>
                                            <td><%= tmpl.created_at %></td>
                                            <td><%= tmpl.modified_at %></td>
                                            <td>
                                                <button class="btn btn-danger btn-sm" onclick="deleteTemplate('<%= tmpl._id %>', '<%= (tmpl.subject || '').replace(/'/g, "\\'") %>', '<%= tmpl.eventId || '' %>')">
                                                    <%= t('common.delete') %>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<%- include ("./components/footer") %>
<script>
(function($) {
    function deleteTemplate(templateId, templateSubject, eventId) {
        const msg = t('email_template_list.confirmDelete').replace('{subject}', templateSubject);
        if (confirm(msg)) {
            const deleteUrl = eventId
                ? '/events/' + eventId + '/emailTemplate/' + templateId
                : '/emailTemplate/' + templateId;

            $.ajax({
                url: deleteUrl,
                type: 'DELETE',
                success: function() { location.reload(); },
                error: function() { alert(t('email_template_list.deleteFailed')); }
            });
        }
    }
    window.deleteTemplate = deleteTemplate;

    $(document).ready(function() {
        // 郵件鏈接使用默認行為（href 直接導向）
        // 無需額外 JavaScript 處理
    });
})(jQuery);
</script>
<script src="/admin/assets/js/lib/data-table/datatables.min.js"></script>
<script src="/admin/assets/js/lib/data-table/dataTables.bootstrap.min.js"></script>
<script src="/admin/assets/js/init/datatables-init.js"></script>
<script type="text/javascript">
    $(document).ready(function () { $('#bootstrap-data-table').DataTable(); });
</script>
