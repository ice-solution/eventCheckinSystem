<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'zh-Hant' %>">
<head>
    <meta charset="UTF-8">
    <title><%= t('qrcode_login.pageTitle') %></title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: rgb(0, 46, 93);
            color: white;
            font-family: Arial, sans-serif;
        }
        img {
            width: 500px;
            height: auto;
        }
    </style>
</head>
<body>

    <div>
        <h1><%= t('qrcode_login.heading') %></h1>
        <img src="<%= qrCodeImage %>" alt="<%= t('qrcode_login.qrCodeAlt') %><%= eventId %>">
        <p><%= t('qrcode_login.eventIdLabel') %><%= eventId %></p>
    </div>

</body>
</html>
