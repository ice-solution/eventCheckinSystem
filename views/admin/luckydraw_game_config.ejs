<%- include("components/header") %>
<%- include("components/menu", { eventId: eventId }) %>
<%- include("components/responsive_layout_style") %>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">

<div id="right-panel" class="right-panel">
    <%- include("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('luckydraw_game_config.title') %> - <%= event.name %></strong>
                            <a href="/events/<%= eventId %>/luckydraw_setting" class="btn btn-sm btn-outline-secondary float-right"><%= t('luckydraw_game_config.settingLink') %></a>
                        </div>
                        <div class="card-body">
                            <p class="text-muted"><%= t('luckydraw_game_config.desc') %> <code>GET /events/<%= eventId %>/luckydraw-config</code></p>
                            <div class="form-group">
                                <label><%= t('luckydraw_game_config.configLabel') %></label>
                                <button type="button" class="btn btn-sm btn-outline-secondary ml-2" id="btnDefault"><%= t('luckydraw_game_config.loadDefault') %></button>
                                <button type="button" class="btn btn-sm btn-outline-info ml-1" id="btnFormat"><%= t('luckydraw_game_config.format') %></button>
                                <textarea id="configJson" class="form-control font-monospace mt-2" rows="24" style="font-size: 13px;"></textarea>
                                <script type="application/json" id="configData"><%- JSON.stringify(config) %></script>
                                <small class="text-muted"><%= t('luckydraw_game_config.note') %></small>
                            </div>
                            <button type="button" id="btnSave" class="btn btn-primary"><%= t('common.save') %></button>
                            <span id="saveStatus" class="ml-2"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("components/footer") %>
<script>
(function() {
    const configDataEl = document.getElementById('configData');
    const defaultConfig = configDataEl ? JSON.parse(configDataEl.textContent || '{}') : {};
    document.getElementById('configJson').value = JSON.stringify(defaultConfig, null, 2);

    const eventId = '<%= eventId %>';

    document.getElementById('btnDefault').addEventListener('click', function() {
        document.getElementById('configJson').value = JSON.stringify(defaultConfig, null, 2);
    });

    document.getElementById('btnFormat').addEventListener('click', function() {
        const ta = document.getElementById('configJson');
        try {
            ta.value = JSON.stringify(JSON.parse(ta.value), null, 2);
            document.getElementById('saveStatus').textContent = '<%= t("luckydraw_game_config.formatted") %>';
            document.getElementById('saveStatus').className = 'ml-2 text-success';
        } catch (e) {
            document.getElementById('saveStatus').textContent = '<%= t("luckydraw_game_config.jsonError") %>';
            document.getElementById('saveStatus').className = 'ml-2 text-danger';
        }
    });

    document.getElementById('btnSave').addEventListener('click', function() {
        const ta = document.getElementById('configJson');
        const status = document.getElementById('saveStatus');
        let config;
        try {
            config = JSON.parse(ta.value);
        } catch (e) {
            status.textContent = '<%= t("luckydraw_game_config.jsonErrorSave") %>';
            status.className = 'ml-2 text-danger';
            return;
        }
        status.textContent = '<%= t("luckydraw_game_config.saving") %>';
        status.className = 'ml-2 text-muted';
        fetch('/events/' + eventId + '/luckydraw-config', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ config: config })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                status.textContent = '<%= t("luckydraw_game_config.saved") %>';
                status.className = 'ml-2 text-success';
            } else {
                status.textContent = data.message || '<%= t("luckydraw_game_config.saveFailed") %>';
                status.className = 'ml-2 text-danger';
            }
        })
        .catch(function() {
            status.textContent = '<%= t("luckydraw_game_config.saveFailed") %>';
            status.className = 'ml-2 text-danger';
        });
    });
})();
</script>
