<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'zh-Hant' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('display_awards.pageTitle') %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h1><%= t('display_awards.heading') %></h1>
        <div id="resultContainer">
            <p id="noDraw" class="text-danger"><%= t('display_awards.notStarted') %></p>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const _userDisplayTpl = '<%= t("display_awards.userDisplay") %>';
        const socket = io();

        socket.on('draw_result', function(selectedUsers) {
            document.getElementById('noDraw').style.display = 'none';
            const resultContainer = document.getElementById('resultContainer');
            const resultList = document.createElement('ul');

            selectedUsers.forEach(user => {
                const listItem = document.createElement('li');
                listItem.textContent = _userDisplayTpl.replace('{name}', user.name).replace('{email}', user.email);
                resultList.appendChild(listItem);
            });

            resultContainer.appendChild(resultList);
        });
    </script>
</body>
</html>
