<%- include("components/header") %>
<%- include("components/menu", { eventId: eventId }) %>

<div id="right-panel" class="right-panel">
    <%- include("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('edit_event_name.title') %></strong>
                        </div>
                        <div class="card-body">
                            <form id="editEventNameForm">
                                <div class="form-group">
                                    <label for="name"><%= t('edit_event_name.label') %></label>
                                    <input type="text" class="form-control" id="name" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><%= t('common.save') %></button>
                                <a href="/events/list" class="btn btn-secondary"><%= t('common.backToEvents') %></a>
                            </form>
                            <div id="alertContainer" class="mt-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("components/footer") %>
<script>
    const eventId = '<%= eventId %>';
    const initialName = <%- JSON.stringify(typeof eventName !== 'undefined' ? eventName : '') %>;
    $(function() {
        $('#name').val(initialName);
        $('#editEventNameForm').on('submit', function(e) {
            e.preventDefault();
            const name = $('#name').val().trim();
            if (!name) {
                alert('<%= t("edit_event_name.required") %>');
                return;
            }
            const btn = $(this).find('button[type="submit"]');
            btn.prop('disabled', true).text('<%= t("edit_event_name.saving") %>');
            $.ajax({
                url: '/events/' + eventId + '/name',
                type: 'PATCH',
                contentType: 'application/json',
                data: JSON.stringify({ name: name }),
                success: function() {
                    $('#alertContainer').html(
                        '<div class="alert alert-success"><%= t("edit_event_name.saved") %></div>'
                    );
                    document.title = name + ' - Edit';
                },
                error: function(xhr) {
                    let msg = '<%= t("edit_event_name.error") %>';
                    try {
                        const j = JSON.parse(xhr.responseText);
                        if (j.message) msg = j.message;
                    } catch (_) {}
                    $('#alertContainer').html(
                        '<div class="alert alert-danger">' + msg + '</div>'
                    );
                },
                complete: function() {
                    btn.prop('disabled', false).text('<%= t("common.save") %>');
                }
            });
        });
    });
</script>
