                    if (templates && templates.length > 0) {
                        const typeNames = { welcome: 'Welcome', confirmation: 'Confirmation', reminder: 'Reminder', thankYou: 'Thank You', invitation: 'Invitation' };
                        templates.forEach(function(t) {
                            const typeName = typeNames[t.type] || t.type || 'welcome';
