            $.ajax({
                url: `/events/<%= event._id %>/users/batch-send-sms`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    userIds: selectedIds,
                    templateId: templateId,
                    sendToSelectedOnly: true
                }),
                success: function(response) {
                    $('#batchSendSmsModal').modal('hide');
                    button.prop('disabled', false).html('<i class="fas fa-paper-plane"></i> ' + _US.confirmSend);
                    let resultsHtml = `
                        <div class="alert alert-info">
                            <h6><i class="fas fa-info-circle"></i> ${_US.batchEmailSummaryTitle}</h6>
                            <p><strong>${_US.successLabel}:</strong> <span class="badge badge-success">${response.successCount || 0}</span></p>
                            <p><strong>${_US.failedLabel}:</strong> <span class="badge badge-danger">${response.failCount || 0}</span></p>
                            <p><strong>${_US.totalLabel}:</strong> ${response.total || 0}</p>
                        </div>
                    `;
                    if (response.results && response.results.length > 0) {
                        resultsHtml += '<h6>' + _US.detailsLabel + '</h6><div style="max-height: 400px; overflow-y: auto;"><table class="table table-sm table-bordered"><thead><tr><th>' + _US.nameColLabel + '</th><th>' + _US.phoneColLabel + '</th><th>' + _US.statusColLabel + '</th></tr></thead><tbody>';
                        response.results.forEach(function(r) {
                            const status = r.success ? '<span class="badge badge-success">' + _US.successLabel + '</span>' : '<span class="badge badge-danger">' + (r.error || _US.failedLabel) + '</span>';
                            resultsHtml += `<tr><td>${r.name || '-'}</td><td>${r.phone || '-'}</td><td>${status}</td></tr>`;
                        });
                        resultsHtml += '</tbody></table></div>';
                    }
                    $('#batchSendSmsResultsContent').html(resultsHtml);
                    $('#batchSendSmsResultsModal').modal('show');
                    showAlert('success', response.message || _US.smsSentSuccess);
                    updateBatchSendEmailButton();
                    updateBatchSendSmsButton();
                },
                error: function(xhr) {
                    button.prop('disabled', false).html('<i class="fas fa-paper-plane"></i> ' + _US.confirmSend);
                    const msg = xhr.responseJSON && xhr.responseJSON.message ? xhr.responseJSON.message : 'Failed to send SMS.';
                    showAlert('danger', msg);
                }
            });
        });

        // Load email templates for batch send based on email type
        function loadBatchEmailTemplates(emailType) {
            const $templateSelect = $('#batchEmailTemplate');
            const $templateGroup = $('#batchEmailTemplateGroup');
            const event_id = '<%= event._id %>';
            
            $templateSelect.html('<option value="">' + _US.useDefaultTemplate + '</option>');
            $templateGroup.hide();
            
            if (!emailType) {
                return;
            }
            
            $.ajax({
                url: `/events/api/${event_id}/emailTemplates`,
                type: 'GET',
                data: { type: emailType },
                success: function(templates) {
                    if (templates && templates.length > 0) {
                        templates.forEach(function(template) {
                            const label = template.eventId ?
                                `${template.subject} ` + _US.eventTemplateLabel :
                                `${template.subject} ` + _US.globalTemplateLabel;
                            $templateSelect.append(`<option value="${template._id}">${label}</option>`);
                        });
                        $templateGroup.show();
                    }
                },
                error: function(xhr) {
                    console.error('Error fetching email templates:', xhr);
                    // If error, just hide the template group
                    $templateGroup.hide();
                }
            });
        }
        
        // Listen for email type changes in batch send modal
        $('#batchEmailType').on('change', function() {
            const emailType = $(this).val();
            loadBatchEmailTemplates(emailType);
        });
        
        // Confirm batch send email
        $('#confirmBatchSendEmail').on('click', function() {
            // Get all selected user IDs from the Set (includes all pages)
            const selectedIds = Array.from(selectedUserIds);

            if (selectedIds.length === 0) {
                showAlert('warning', _US.batchEmailNoUsers);
                closeBatchSendEmailModal();
                return;
            }

            const emailType = $('#batchEmailType').val();
            if (!emailType) {
                showAlert('warning', _US.batchEmailNoType);
                return;
            }

            const emailTemplateId = $('#batchEmailTemplate').val() || null; // 可選的模板 ID

            const button = $(this);
            const originalText = button.html();
            button.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> ' + _US.sending);

            $.ajax({
                url: `/events/<%= event._id %>/users/batch-send-email`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ 
                    userIds: selectedIds,
                    emailType: emailType,
                    emailTemplateId: emailTemplateId
                }),
                success: function(response) {
                    closeBatchSendEmailModal();
                    const results = response.results || {};
                    const emailType = response.emailType || 'unknown';
                    
                    let resultsHtml = `
                        <div class="alert alert-info">
                            <h6><i class="fas fa-info-circle"></i> ${_US.batchEmailSummaryTitle}</h6>
                            <p><strong>${_US.emailTypeResultLabel}:</strong> ${emailType}</p>
                            <p><strong>${_US.successLabel}:</strong> <span class="badge badge-success">${results.success}</span></p>
                            <p><strong>${_US.failedLabel}:</strong> <span class="badge badge-danger">${results.failed}</span></p>
                            <p><strong>${_US.skippedLabel}:</strong> <span class="badge badge-warning">${results.skipped}</span></p>
                        </div>
                    `;

                    if (results.details && results.details.length > 0) {
                        resultsHtml += `
                            <h6>${_US.detailedRecordsTitle}</h6>
                            <div style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            <th>${_US.nameColLabel}</th>
                                            <th>${_US.emailColLabel}</th>
                                            <th>${_US.statusColLabel}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                        `;

                        results.details.forEach(function(detail) {
                            let statusBadge = '';
                            if (detail.status === 'success') {
                                statusBadge = '<span class="badge badge-success">' + _US.successLabel + '</span>';
                            } else if (detail.status === 'failed') {
                                statusBadge = '<span class="badge badge-danger">' + _US.failedLabel + ': ' + (detail.error || 'Unknown error') + '</span>';
                            } else {
                                statusBadge = '<span class="badge badge-warning">' + _US.skippedLabel + ': ' + (detail.error || 'N/A') + '</span>';
                            }
                            
                            resultsHtml += `
                                <tr>
                                    <td>${detail.name || '-'}</td>
                                    <td>${detail.email || '-'}</td>
