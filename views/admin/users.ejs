        // --- 進階搜尋：多條件 AND（例如 姓名=John doe 且 公司=government）---
        const searchableFieldNames = [];
        <% if (formConfig && formConfig.sections) { %>
            <% const jsSortedSections = [...formConfig.sections].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
            <% jsSortedSections.forEach(section => { %>
                <% if (section.visible && section.fields) { %>
                    <% const jsSortedFields = [...section.fields].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                    <% jsSortedFields.forEach(field => { %>
                        <% if (field.visible) { %>
                            searchableFieldNames.push('<%= field.fieldName %>');
                        <% } %>
                    <% }); %>
                <% } %>
            <% }); %>
        <% } else { %>
            searchableFieldNames.push('email', 'name', 'company', 'phone');
        <% } %>
        <% if (formConfig && formConfig.agreement && formConfig.agreement.enabled) { %>
            searchableFieldNames.push('agreementAgreed', 'agreementRecordedAt');
        <% } %>

        // 條件陣列：{ field: 'name', term: 'john doe' }，須全部符合 (AND)
        let advancedSearchConditions = [];

        $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
            if (advancedSearchConditions.length === 0) return true;
            const row = table.row(dataIndex).node();
            const $row = $(row);
            for (let i = 0; i < advancedSearchConditions.length; i++) {
                const c = advancedSearchConditions[i];
                if (!c.field || !c.term || c.term.trim() === '') continue;
                const cellText = ($row.find('td[data-field-name="' + c.field + '"]').text() || '').trim().toLowerCase();
                const term = c.term.trim().toLowerCase();
                if (cellText.indexOf(term) === -1) return false; // 任一條件不符合則不顯示
            }
            return true;
        });

        function readConditionsFromForm() {
            const conditions = [];
            $('#advancedSearchConditionsContainer .advanced-search-condition-row').each(function() {
                const field = $(this).find('.advancedSearchField').val();
                const term = ($(this).find('.advancedSearchInput').val() || '').trim();
                if (field && term) conditions.push({ field: field, term: term });
            });
            return conditions;
        }

        function populateFormFromConditions(conditions) {
            const $container = $('#advancedSearchConditionsContainer');
            const $templateRow = $container.find('.advanced-search-condition-row').first();
            if (!$templateRow.length) return;
            const rowCount = Math.max((conditions && conditions.length) || 0, 2);
            $container.empty();
            for (let i = 0; i < rowCount; i++) {
                const $row = $templateRow.clone();
                const c = conditions && conditions[i];
                $row.find('.advancedSearchField').val(c ? c.field : '');
                $row.find('.advancedSearchInput').val(c ? c.term : '');
                $row.attr('data-index', i + 1);
                $row.find('label.col-form-label').text(_US.conditionLabel + ' ' + (i + 1));
                $container.append($row);
            }
            updateRemoveButtons();
            renumberConditionLabels();
        }

        function applyAdvancedSearch() {
            advancedSearchConditions = readConditionsFromForm();
            table.draw();
        }

        function updateRemoveButtons() {
            const rows = $('#advancedSearchConditionsContainer .advanced-search-condition-row');
            rows.each(function(i) {
                const $wrap = $(this).find('.advanced-search-remove-wrap');
                if (rows.length > 2) $wrap.show(); else $wrap.hide();
            });
        }

        function renumberConditionLabels() {
            $('#advancedSearchConditionsContainer .advanced-search-condition-row').each(function(i) {
                $(this).find('label.col-form-label').text(_US.conditionLabel + ' ' + (i + 1));
                $(this).attr('data-index', i + 1);
            });
        }

        // Bind add condition button with direct handler (event delegation doesn't work reliably with this element)
        function bindAddConditionButton() {
            $('#advancedSearchAddCondition').off('click').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();

                // Limit to maximum 8 filters
                const currentRows = $('#advancedSearchConditionsContainer .advanced-search-condition-row').length;
                if (currentRows >= 8) {
                    showAlert('warning', 'Maximum 8 filters allowed');
                    return;
                }

                const $firstRow = $('#advancedSearchConditionsContainer .advanced-search-condition-row').first();
                const $newRow = $firstRow.clone().removeAttr('data-index').addClass('advanced-search-condition-row').attr('data-index', currentRows + 1);
                $newRow.find('.advancedSearchField').val('');
                $newRow.find('.advancedSearchInput').val('');
                $newRow.find('label.col-form-label').text(_US.conditionLabel + ' ' + (currentRows + 1));
                $('#advancedSearchConditionsContainer').append($newRow);
                updateRemoveButtons();
                renumberConditionLabels();
            });
        }
        bindAddConditionButton();

        // Use document delegation for remove button since it may be in modal
        $(document).on('click', '.advanced-search-remove', function(e) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            const $row = $(this).closest('.advanced-search-condition-row');
            if ($('#advancedSearchConditionsContainer .advanced-search-condition-row').length <= 2) return;
            $row.remove();
            renumberConditionLabels();
            updateRemoveButtons();
            return false;
        });

        // Bind clear button with direct handler
        function bindClearButton() {
            $('#advancedSearchClear').off('click').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#advancedSearchConditionsContainer .advanced-search-condition-row').each(function(i) {
                    $(this).find('.advancedSearchField').val('');
                    $(this).find('.advancedSearchInput').val('');
                });
                $('#advancedSearchConditionsContainer .advanced-search-condition-row').slice(2).remove();
                renumberConditionLabels();
                updateRemoveButtons();
            });
        }
        bindClearButton();

        // Filter Modal Control
        let filterModalInitialized = false;

        function showFilterModal() {
            const $advancedSearchPanel = $('.advanced-search-panel');
            const $filterModalContent = $('#filterModalContent');

            // Move advanced search panel to modal on first open
            if (!filterModalInitialized && $advancedSearchPanel.length) {
                const $panel = $advancedSearchPanel.detach();
                $panel.css('display', 'block'); // Ensure it displays in modal
                $filterModalContent.append($panel);
                filterModalInitialized = true;
            }

            populateFormFromConditions(advancedSearchConditions);
            $('#filterModalBackdrop').show();
            $('#filterModal').show();
        }

        function hideFilterModal(discardDraft) {
            if (discardDraft !== false) {
                populateFormFromConditions(advancedSearchConditions);
            }
            $('#filterModalBackdrop').hide();
            $('#filterModal').hide();
        }

