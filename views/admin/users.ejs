                                                            <img src="https://api.qrserver.com/v1/create-qr-code/?data=<%= user._id %>&size=200x200" alt="QR Code" class="qrcode-image" id="qrcode-<%= user._id %>">
                                                            <button type="button" class="btn btn-primary btn-sm qrcode-download-btn" data-user-id="<%= user._id %>" data-user-name="<%= user.name || user.email %>">
                                                                <i class="fa fa-download"></i> <%= t('users.downloadQrCodeBtn') %>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="btn-group">
                                                        <button type="button" class="btn btn-outline-primary dropdown-toggle resend-email-btn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" data-_id="<%= user._id %>">
                                                            <i class="fa fa-envelope mr-1"></i> <%= t('users.resendDropdown') %>
                                                        </button>
                                                        <div class="dropdown-menu">
                                                            <a class="dropdown-item resend-email-option" href="#" data-type="invitation"><%= t('users.emailTypeInvitation') %></a>
                                                            <a class="dropdown-item resend-email-option" href="#" data-type="welcome"><%= t('users.emailTypeWelcome') %></a>
                                                            <a class="dropdown-item resend-email-option" href="#" data-type="knowledge"><%= t('users.emailTypeKnowledge') %></a>
                                                            <a class="dropdown-item resend-email-option" href="#" data-type="reminder"><%= t('users.emailTypeReminder') %></a>
                                                            <% if (invoiceEmailEnabled) { %>
                                                            <a class="dropdown-item resend-email-option" href="#" data-type="invoice"><%= t('users.emailTypeInvoice') %></a>
                                                            <% } %>
                                                            <a class="dropdown-item resend-email-option" href="#" data-type="payment_receipt"><%= t('users.emailTypePaymentReceipt') %></a>
                                                        </div>
                                                    </div>
                                                    <button class="btn btn-delete-x delete-user" data-_id="<%= user._id %>" title="<%= t('common.delete') %>">✕</button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                            </div><!-- /.users-table-area -->
                        </div>
                    </div>
            </div>
        </div>
    </div>
</div>

