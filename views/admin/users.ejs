        // Store resend email context
        let resendEmailContext = {
            userId: null,
            emailType: null,
            button: null,
            originalHtml: null
        };

        // Resend email functionality (支持選擇類型)
        $('#usersTable tbody').on('click', '.resend-email-option', function(e) {
            e.preventDefault();
            const _id = $(this).closest('.btn-group').find('.resend-email-btn').data('_id');
            const emailType = $(this).data('type');
            const event_id = '<%= event._id %>';
            const button = $(this).closest('.btn-group').find('.resend-email-btn');
            const originalHtml = button.html();

            // Store context for later use
            resendEmailContext = {
                userId: _id,
                emailType: emailType,
                button: button,
                originalHtml: originalHtml
            };

            // Load templates for this type
            const $templateSelect = $('#resendEmailTemplate');
            const $templateGroup = $('#resendEmailTemplateGroup');
            
            $templateSelect.html('<option value="">' + _US.useDefaultTemplate + '</option>');
            $templateGroup.hide();

            $.ajax({
                url: `/events/api/${event_id}/emailTemplates`,
                type: 'GET',
                data: { type: emailType },
                success: function(templates) {
                    if (templates && templates.length > 0) {
                        templates.forEach(function(template) {
                            const label = template.eventId ?
                                `${template.subject} ` + _US.eventTemplateLabel :
                                `${template.subject} ` + _US.globalTemplateLabel;
                            $templateSelect.append(`<option value="${template._id}">${label}</option>`);
                        });
                        $templateGroup.show();
                    }
                    
                    // Show modal for template selection
                    const $modal = $('#resendEmailModal');
                    if ($modal.length === 0) {
                        console.error('Resend email modal not found!');
                        showAlert('danger', _US.modalNotFound);
                        return;
                    }
                    
                    // Reset modal state before showing
                    $modal.removeClass('show').attr('aria-hidden', 'false');
                    
                    // Show modal - Bootstrap 4 syntax
                    $modal.modal('show');
                    
                    // Ensure modal is visible (fallback if Bootstrap doesn't work)
                    setTimeout(function() {
                        if (!$modal.hasClass('show') || $modal.css('display') === 'none') {
                            $modal.addClass('show').css('display', 'block');
                            $('body').addClass('modal-open');
                            if ($('.modal-backdrop').length === 0) {
                                $('<div class="modal-backdrop fade show"></div>').appendTo('body');
                            }
                        }
                    }, 200);
                },
                error: function(xhr) {
                    console.error('Error fetching email templates:', xhr);
                    // If error, proceed with default template
                    confirmResendEmail();
                }
            });
        });

        // Confirm resend email (with template selection)
        function confirmResendEmail() {
            const emailTemplateId = $('#resendEmailTemplate').val() || null;
            const event_id = '<%= event._id %>';
            const { userId, emailType, button, originalHtml } = resendEmailContext;

            if (!userId || !emailType) {
                showAlert('danger', _US.missingResendInfo);
                return;
            }

            button.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>');

            $.ajax({
                url: `/events/${event_id}/users/${userId}/resend-email`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ 
                    emailType: emailType,
                    emailTemplateId: emailTemplateId
                }),
                success: function() {
                    showAlert('success', _US.resendSuccess.replace('{type}', emailType));
                    const $modal = $('#resendEmailModal');
                    $modal.modal('hide');
                    // Cleanup modal state
                    setTimeout(function() {
                        $modal.removeClass('show').attr('aria-hidden', 'true');
                        $('.modal-backdrop').remove();
                        $('body').removeClass('modal-open').css({
                            'padding-right': '',
                            'overflow': ''
                        });
                    }, 300);
                },
                error: function(xhr) {
                    showAlert('danger', _US.resendFailed);
                },
                complete: function() {
                    button.prop('disabled', false).html(originalHtml);
                }
            });
        }

