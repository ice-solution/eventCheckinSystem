        $('#emailSettingsModalClose, #emailSettingsModalCloseBtn, #emailSettingsModalBackdrop').on('click', function(e) {
            if ($(e.target).is('#emailSettingsModalBackdrop') || $(e.target).is('#emailSettingsModalClose') || $(e.target).is('#emailSettingsModalCloseBtn')) {
                $('#emailSettingsModalBackdrop').css('display', 'none');
