        function syncSelectWithOtherAdmin(selectEl) {
            if (!selectEl || !selectEl.getAttribute('data-select-other-base')) return;
            var base = selectEl.getAttribute('data-select-other-base');
            var hidden = document.getElementById(base + '_hidden');
            var other = document.getElementById(base + '_other');
            if (!hidden || !other) return;
            var opt = selectEl.options[selectEl.selectedIndex];
            var isOther = opt && opt.getAttribute('data-is-other') === '1';
            if (isOther) {
                $(other).removeClass('d-none');
                if (selectEl.hasAttribute('required')) other.setAttribute('required', 'required');
                else other.removeAttribute('required');
                hidden.value = (other.value || '').trim();
            } else {
                $(other).addClass('d-none');
                other.removeAttribute('required');
                other.value = '';
                other.setCustomValidity('');
                hidden.value = selectEl.value || '';
            }
        }
        $(document).on('change', '#newUserForm .js-select-maybe-other', function() {
            syncSelectWithOtherAdmin(this);
        });
        $(document).on('input', '#newUserForm .js-select-other-text', function() {
            var id = this.id;
            if (!id || id.indexOf('_other') === -1) return;
            var base = id.replace(/_other$/, '');
            var sel = document.getElementById(base + '_sel');
            if (sel) syncSelectWithOtherAdmin(sel);
        });

        $('#newUserForm').on('submit', function(e) {
            e.preventDefault();
            $('#newUserForm .js-select-maybe-other').each(function() { syncSelectWithOtherAdmin(this); });
            var newUserFormEl = document.getElementById('newUserForm');
            $('#newUserForm .js-select-other-text').each(function() {
                if (!$(this).hasClass('d-none') && this.hasAttribute('required') && !((this.value || '').trim())) {
                    this.setCustomValidity(_US.fieldRequired);
                } else {
                    this.setCustomValidity('');
                }
            });
            if (newUserFormEl && !newUserFormEl.checkValidity()) {
                newUserFormEl.reportValidity();
                return;
            }
            
            // Dynamically collect form data
            const userData = {
                isCheckIn: false
            };
            const checkboxFields = {}; // 用於收集 checkbox 字段
            
            $('#newUserForm').find('input, select, textarea').each(function() {
                const $field = $(this);
                const fieldName = $field.attr('name');
                const fieldType = $field.attr('type');
                
                if (fieldName) {
                    // 處理 checkbox 字段（name 以 [] 結尾）
                    if (fieldType === 'checkbox') {
                        const baseName = fieldName.replace(/\[\]$/, '');
                        if (!checkboxFields[baseName]) {
                            checkboxFields[baseName] = [];
                        }
                        if ($field.is(':checked')) {
                            checkboxFields[baseName].push($field.val());
                        }
                    } else {
                        // 處理其他字段類型
                        userData[fieldName] = $field.val();
                    }
                }
            });
            
            // 合併 checkbox 字段到 userData（如果沒有選中任何選項，設為空數組）
            Object.keys(checkboxFields).forEach(function(baseName) {
                userData[baseName] = checkboxFields[baseName].length > 0 ? checkboxFields[baseName] : [];
            });
            
            // 確保必填字段 name 有值（如果表單中沒有 name 字段）
            if (!userData.name || userData.name === '') {
                userData.name = userData.email || userData.company || _US.noNameProvided;
            }

            $.ajax({
                url: `/events/<%= event._id %>/users`,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(userData),
                success: function(response) {
                    // Add new row to DataTable
                    // 動態構建新行數據
                    const newRow = [
                        '<input type="checkbox" class="user-select" data-_id="' + response._id + '" />'
                    ];
                    
                    // 根據formConfig添加字段數據（順序需與 table 欄位一致）
                    const fieldNames = [];
                    <% if (formConfig && formConfig.sections) { %>
                        <% const ajaxSortedSections = [...formConfig.sections].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                        <% ajaxSortedSections.forEach(section => { %>
                            <% if (section.visible && section.fields) { %>
                                <% const ajaxSortedFields = [...section.fields].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                                <% ajaxSortedFields.forEach(field => { %>
                                    <% if (field.visible) { %>
                                        fieldNames.push('<%= field.fieldName %>');
                                        newRow.push(userData['<%= field.fieldName %>'] || '-');
                                    <% } %>
                                <% }); %>
                            <% } %>
                        <% }); %>
                    <% } else { %>
                        // 預設字段
                        fieldNames.push('email');
                        fieldNames.push('name');
                        fieldNames.push('company');
                        fieldNames.push('phone');
                        newRow.push(userData.email || '-');
                        newRow.push(userData.name || '-');
                        newRow.push(userData.company || '-');
                        newRow.push(userData.phone || '-');
                    <% } %>
                    <% if (formConfig && formConfig.agreement && formConfig.agreement.enabled) { %>
                        newRow.push('-');
                        newRow.push('-');
                    <% } %>
                    
                    // 添加 Created At 列
                    const now = new Date();
                    const timestamp = now.getTime();
                    const formattedDate = now.toLocaleString('zh-TW', {
                        timeZone: 'Asia/Hong_Kong',
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit',
                        second: '2-digit',
                        hour12: false
                    });
                    // 直接 push 文本內容，DataTable 會自動創建 td
                    newRow.push(formattedDate);
                    
                    // 添加Checked In和Actions列
                    newRow.push('<input type="checkbox" class="checkin-toggle" data-_id="' + response._id + '" />');
                    const userNameForQR = userData.name || userData.email || 'user';
                    const actionsHtml = '<div class="user-action-buttons">' +
                        '<div class="qrcode-container">' +
                        '<button type="button" class="btn btn-outline-info qrcode-btn" data-user-id="' + response._id + '" title="' + _US.viewQrCode + '"><i class="fa fa-qrcode"></i></button>' +
                        '<div class="qrcode-popup">' +
                        '<img src="https://api.qrserver.com/v1/create-qr-code/?data=' + response._id + '&size=200x200" alt="QR Code" class="qrcode-image" id="qrcode-' + response._id + '">' +
                        '<button type="button" class="btn btn-primary btn-sm qrcode-download-btn" data-user-id="' + response._id + '" data-user-name="' + userNameForQR + '"><i class="fa fa-download"></i> ' + _US.downloadQrCodeBtn + '</button>' +
                        '</div>' +
                        '</div>' +
                        '<div class="btn-group">' +
                        '<button type="button" class="btn btn-outline-primary dropdown-toggle resend-email-btn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" data-_id="' + response._id + '"><i class="fa fa-envelope mr-1"></i> ' + _US.resendDropdown + '</button>' +
                        '<div class="dropdown-menu">' +
                        '<a class="dropdown-item resend-email-option" href="#" data-type="invitation">' + _US.emailTypeInvitation + '</a>' +
                        '<a class="dropdown-item resend-email-option" href="#" data-type="welcome">' + _US.emailTypeWelcome + '</a>' +
                        '<a class="dropdown-item resend-email-option" href="#" data-type="knowledge">' + _US.emailTypeKnowledge + '</a>' +
                        '<a class="dropdown-item resend-email-option" href="#" data-type="reminder">' + _US.emailTypeReminder + '</a>' +
                        (_US.invoiceEmailEnabled ? '<a class="dropdown-item resend-email-option" href="#" data-type="invoice">' + _US.emailTypeInvoice + '</a>' : '') +
                        '<a class="dropdown-item resend-email-option" href="#" data-type="payment_receipt">' + _US.emailTypePaymentReceipt + '</a>' +
                        '</div>' +
                        '</div>' +
                        '<button class="btn btn-delete-x delete-user" data-_id="' + response._id + '" title="' + _US.deleteBtn + '">✕</button>' +
                        '</div>';
                    newRow.push(actionsHtml);
                    
                    const rowNode = table.row.add(newRow).draw().node();
                    $(rowNode).addClass('checkin-false').attr('data-id', response._id);
                    
                    // 為新行的每個數據欄位設置 data-field-name 屬性
                    // 跳過第一個 checkbox 列、Checked In 列和 Actions 列
                    $(rowNode).find('td').each(function(index) {
                        if (index > 0 && index <= fieldNames.length) {
                            $(this).attr('data-field-name', fieldNames[index - 1]);
                        }
                    });
                    
                    // 設置 Created At 列的 data-order 屬性（倒數第 3 列）
                    const totalTds = $(rowNode).find('td').length;
                    const createdAtTdIndex = totalTds - 3;
                    const createdAtTd = $(rowNode).find('td').eq(createdAtTdIndex);
                    if (createdAtTd.length) {
                        createdAtTd.attr('data-order', timestamp);
                    }
                    const checkInTdIndex = totalTds - 2;
                    const checkInTd = $(rowNode).find('td').eq(checkInTdIndex);
                    if (checkInTd.length) {
                        checkInTd.attr('data-order', 0);
                    }
                    
                    // Hide form and show button
                    $('#addUserForm').hide();
                    $('#addUserBtn').show();
                    $('#newUserForm')[0].reset();
                    
                    showAlert('success', _US.addUserSuccess);
                },
                error: function(xhr, status, error) {
                    showAlert('danger', _US.addUserFailed);
                }
            });
        });

        // QR Code hover 顯示功能（使用 mouseenter/mouseleave 確保穩定性）
        // 計算並更新 QR code popup 位置
        function updateQRCodePopupPosition($container) {
            const $popup = $container.find('.qrcode-popup');
            if (!$popup.length) return;
            
            const containerOffset = $container.offset();
            const containerWidth = $container.outerWidth();
            const containerHeight = $container.outerHeight();
            const popupWidth = 230;
            const popupHeight = 250; // 大約的 popup 高度（200px QR + padding + button）
            
            const windowWidth = $(window).width();
            const windowHeight = $(window).height();
            const scrollTop = $(window).scrollTop();
            const scrollLeft = $(window).scrollLeft();
            
            // 計算按鈕在視窗中的位置（考慮 scroll）
            // offset() 返回的是相對於 document 的位置，需要減去 scroll 得到視窗中的位置
            const buttonLeft = containerOffset.left - scrollLeft;
            const buttonRight = buttonLeft + containerWidth;
            const buttonTop = containerOffset.top - scrollTop;
            const buttonCenterY = buttonTop + containerHeight / 2;
            
            // 計算右側和左側的可用空間
            const spaceRight = windowWidth - buttonRight;
            const spaceLeft = buttonLeft;
            
            let popupLeft, popupTop;
            let positionClass = 'popup-right'; // 預設顯示在右側
            
            // 決定顯示位置：優先顯示在右側，如果右側空間不夠則顯示在左側
            if (spaceRight >= popupWidth + 10) {
                // 顯示在右側
                popupLeft = buttonRight + 10; // fixed 定位，直接使用視窗座標
                positionClass = 'popup-right';
            } else if (spaceLeft >= popupWidth + 10) {
                // 顯示在左側
                popupLeft = buttonLeft - popupWidth - 10; // fixed 定位，直接使用視窗座標
                positionClass = 'popup-left';
            } else {
                // 兩邊空間都不夠，選擇空間較大的一邊
                if (spaceRight > spaceLeft) {
                    popupLeft = buttonRight + 5; // 緊貼右側
                    positionClass = 'popup-right';
                } else {
                    popupLeft = buttonLeft - popupWidth - 5; // 緊貼左側
                    positionClass = 'popup-left';
                }
            }
            
            // 計算垂直位置（對齊按鈕中間，但確保不超出視窗）
            popupTop = buttonCenterY - popupHeight / 2;
            
            // 確保不超出視窗上下邊界
            if (popupTop < 10) {
                popupTop = 10;
            } else if (popupTop + popupHeight > windowHeight - 10) {
                popupTop = windowHeight - popupHeight - 10;
            }
            
            // 確保不超出視窗左右邊界
            if (popupLeft < 10) {
                popupLeft = 10;
            } else if (popupLeft + popupWidth > windowWidth - 10) {
                popupLeft = windowWidth - popupWidth - 10;
            }
            
            // 移除舊的 position class 並添加新的
            $popup.removeClass('popup-above popup-below popup-left popup-right').addClass(positionClass);
            
            // 設置 fixed 位置（fixed 定位是相對於視窗的，不需要加 scroll）
            $popup.css({
                'position': 'fixed',
                'left': popupLeft + 'px',
                'top': popupTop + 'px',
                'display': 'block'
            });
        }
        
        $(document).on('mouseenter', '.qrcode-container', function(e) {
            e.stopPropagation();
            const $container = $(this);
            updateQRCodePopupPosition($container);
        });
        
        // 當頁面滾動時，更新所有顯示中的 QR code popup 位置
        let scrollTimeout;
        $(window).on('scroll', function() {
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(function() {
                $('.qrcode-popup:visible').each(function() {
                    const $container = $(this).closest('.qrcode-container');
                    if ($container.length) {
                        updateQRCodePopupPosition($container);
                    }
                });
            }, 10); // 稍微延遲以提升性能
        });
        
        $(document).on('mouseleave', '.qrcode-container', function(e) {
            e.stopPropagation();
            const $popup = $(this).find('.qrcode-popup');
            // 稍微延遲隱藏，以便用戶可以移動到 popup
            setTimeout(function() {
                if (!$popup.is(':hover')) {
                    $popup.css('display', 'none');
                }
            }, 200);
        });
        
        $(document).on('mouseenter', '.qrcode-popup', function(e) {
            e.stopPropagation();
        });
        
        $(document).on('mouseleave', '.qrcode-popup', function(e) {
            e.stopPropagation();
            $(this).css('display', 'none');
        });

        // QR Code 下載功能
        $(document).on('click', '.qrcode-download-btn', function(e) {
            e.preventDefault();
            e.stopPropagation();
            const userId = $(this).data('user-id');
            const userName = $(this).data('user-name') || 'user';
            // 清理文件名中的特殊字符
            const cleanUserName = userName.replace(/[^a-zA-Z0-9\-_]/g, '_');
            const qrcodeUrl = `https://api.qrserver.com/v1/create-qr-code/?data=${userId}&size=500x500`;
            
            // 創建臨時圖片元素以下載
            const img = new Image();
            img.crossOrigin = 'Anonymous';
            img.onload = function() {
                const canvas = document.createElement('canvas');
                canvas.width = img.width;
                canvas.height = img.height;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0);
                
                // 轉換為 blob 並下載
                canvas.toBlob(function(blob) {
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `qrcode-${cleanUserName}-${userId}.png`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                }, 'image/png');
            };
            img.onerror = function() {
                // 如果 crossOrigin 失敗，直接下載 URL
                const a = document.createElement('a');
                a.href = qrcodeUrl;
                a.download = `qrcode-${cleanUserName}-${userId}.png`;
                a.target = '_blank';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            };
            img.src = qrcodeUrl;
        });

    });
</script>
<script>
(function () {
    const row = document.getElementById('btnScrollRow');
    if (!row) return;
    let drag = { active: false, x: 0, scroll: 0, moved: false };
    row.addEventListener('mousedown', function (e) {
        drag = { active: true, x: e.clientX, scroll: row.scrollLeft, moved: false };
        row.classList.add('is-dragging');
    });
    window.addEventListener('mouseup', function () {
        drag.active = false;
        row.classList.remove('is-dragging');
    });
    row.addEventListener('mousemove', function (e) {
        if (!drag.active) return;
        const dx = drag.x - e.clientX;
        if (Math.abs(dx) > 5) drag.moved = true;
        row.scrollLeft = drag.scroll + dx;
    });
    row.addEventListener('click', function (e) {
        if (drag.moved) { e.preventDefault(); e.stopPropagation(); drag.moved = false; }
    }, true);
})();
</script>

