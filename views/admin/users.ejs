            showFilterModal();
        });

        $('#filterModalClose').on('click', function() {
            hideFilterModal(true);
        });

        $('#filterDoneBtn').on('click', function() {
            applyAdvancedSearch();
            hideFilterModal(false);
        });

        $('#filterModalBackdrop').on('click', function() {
