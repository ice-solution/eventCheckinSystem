                                            <td><input type="checkbox" class="user-select" data-_id="<%= user._id %>" /></td>
                                            <% if (formConfig && formConfig.sections) { %>
                                                <% const sortedSections = [...formConfig.sections].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                                                <% sortedSections.forEach(section => { %>
