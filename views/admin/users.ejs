        // Batch check in button click
        $('#batchCheckInBtn').on('click', function() {
            const totalUsers = <%= event.users.length %>;
            const alreadyCheckedIn = <%= event.users.filter(u => u.isCheckIn).length %>;
            const toCheckIn = totalUsers - alreadyCheckedIn;

            if (toCheckIn === 0) {
                showAlert('info', _US.batchCheckInAllDone);
                return;
            }

            const confirmMsg = _US.batchCheckInConfirm.replace('{total}', totalUsers).replace('{checked}', alreadyCheckedIn).replace('{add}', toCheckIn);
            if (confirm(confirmMsg)) {
                const button = $(this);
                const originalText = button.text();
                button.prop('disabled', true).text(_US.processing);

                $.ajax({
                    url: `/events/<%= event._id %>/users/batch-checkin`,
                    type: 'PUT',
                    contentType: 'application/json',
                    success: function(response) {
                        $('#usersTable tbody tr').each(function() {
                            const row = $(this);
                            const checkInCheckbox = row.find('.checkin-toggle');
                            if (!checkInCheckbox.is(':checked')) {
                                checkInCheckbox.prop('checked', true);
                                row.removeClass('checkin-false').addClass('checkin-true');
                            }
                        });
                        showAlert('success', _US.batchCheckInSuccess.replace('{count}', response.checkedInCount));
                        button.prop('disabled', false).text(originalText);
                    },
                    error: function(xhr, status, error) {
                        showAlert('danger', _US.batchCheckInFailed);
                        button.prop('disabled', false).text(originalText);
                    }
                });
            }
        });

        // Add inline editing functionality
        $('#usersTable tbody').on('dblclick', 'td:not(:last-child):not(:nth-last-child(2)):not(:first-child):not(.agreement-meta-cell)', function() {
            const cell = $(this);
            const currentText = cell.text().trim();
            // Try multiple ways to get field-name (compatible with data-field-name and data-fieldName)
            let fieldName = cell.attr('data-field-name') || cell.data('field-name') || cell.data('fieldName');
            const row = cell.closest('tr');
            const userId = row.data('id') || row.attr('data-id');
            
            // Debug log
            console.log('Double-click detected:', {
                cell: cell[0],
                fieldName: fieldName,
                userId: userId,
                currentText: currentText,
                allAttributes: cell[0] ? Array.from(cell[0].attributes).map(attr => `${attr.name}="${attr.value}"`).join(', ') : 'N/A'
            });
            
            // If no field-name attribute, skip editing
            if (!fieldName) {
                console.warn('No field-name attribute found for this cell. Cell HTML:', cell[0] ? cell[0].outerHTML : 'N/A');
                return;
            }
            
            if (!userId) {
                console.warn('No user ID found for this row');
                return;
            }
            
            // Create input field
            const input = $('<input>', {
                type: 'text',
                value: currentText,
                class: 'form-control form-control-sm'
            });
            
            // Replace cell content with input
            cell.html(input);
            input.focus();
            
            // Handle input events
            input.on('blur keypress', function(e) {
                if (e.type === 'blur' || e.which === 13) { // Enter key or blur
                    const newValue = input.val();
                    cell.text(newValue);
                    
                    // Send update to server
                    updateUserField(userId, fieldName, newValue);
                }
            });
        });
        
        // Function to update user field
        function updateUserField(userId, fieldName, newValue) {
            if (!fieldName) {
                showAlert('danger', _US.errorNoFieldName);
                return;
            }

            if (!userId) {
                showAlert('danger', _US.errorNoUserId);
                return;
            }
            
            // Build request data
            const updateData = {};
            updateData[fieldName] = newValue;
            
            console.log('Updating field:', {
                userId: userId,
                fieldName: fieldName,
                newValue: newValue,
                requestData: updateData
            });
            
            $.ajax({
                url: `/events/<%= event._id %>/users/${userId}`,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify(updateData),
                success: function(response) {
                    showAlert('success', _US.updateSuccess);
                },
                error: function(xhr) {
                    showAlert('danger', _US.updateFailed + ' ' + (xhr.responseText || xhr.statusText));
                }
            });
        }
        
        // Function to show alerts
        function showAlert(type, message) {
            const id = 'toast-' + Date.now();
            const $toast = $(`<div id="${id}" style="
                position:fixed; top:20px; left:50%; transform:translateX(-50%);
                z-index:99999; min-width:300px; max-width:520px;
                box-shadow:0 4px 16px rgba(0,0,0,0.15); border-radius:8px;
            " class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>`);
            $('body').append($toast);
            setTimeout(() => $toast.fadeOut(300, function() { $(this).remove(); }), 3500);
        }

