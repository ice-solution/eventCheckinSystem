                                    <h5 style="margin: 0;"><%= t('users.advancedSearchTitle') || 'Filter' %></h5>
                                    <button type="button" id="filterModalClose" style="display: none; background: none; border: none; font-size: 24px; cursor: pointer; color: #666;">&times;</button>
