        // Batch delete button click
        $('#batchDeleteBtn').on('click', function() {
            // Get all selected user IDs from the Set (includes all pages)
            const selectedIds = Array.from(selectedUserIds);

            if (selectedIds.length === 0) {
                showAlert('warning', _US.batchDeleteFailed);
                return;
            }

            if (confirm(_US.batchDeleteConfirm.replace('{count}', selectedIds.length))) {
                // Send all user IDs in one request
                $.ajax({
                    url: `/events/<%= event._id %>/users/batch`,
                    type: 'DELETE',
                    contentType: 'application/json',
                    data: JSON.stringify({ userIds: selectedIds }),
                    success: function(response) {
                        // Remove all selected user IDs from the set
                        selectedIds.forEach(userId => {
                            selectedUserIds.delete(userId);
                            // Try to remove from table if visible
                            const row = $(`.user-select[data-_id="${userId}"]`).closest('tr');
                            if (row.length) {
                                table.row(row).remove();
                            }
                        });
                        table.draw();
                        
                        showAlert('success', _US.batchDeleteSuccess.replace('{count}', response.deletedCount));
                        updateBatchDeleteButton();
                        updateBatchSendEmailButton();
                        updateBatchSendSmsButton();
                        updateSelectAllCheckbox();
                    },
                    error: function(xhr, status, error) {
                        showAlert('danger', _US.batchDeleteFailed);
                    }
                });
            }
        });

