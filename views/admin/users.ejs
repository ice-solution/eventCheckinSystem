                                                if (createdDate) {
                                                    const date = new Date(createdDate);
                                                    const formattedDate = date.toLocaleString('zh-TW', {
                                                        timeZone: 'Asia/Hong_Kong',
                                                        year: 'numeric',
                                                        month: '2-digit',
                                                        day: '2-digit',
                                                        hour: '2-digit',
                                                        minute: '2-digit',
                                                        second: '2-digit',
                                                        hour12: false
                                                    });
                                                %>
                                                    <%= formattedDate %>
                                                <% } else { %>
                                                    -
                                                <% } %>
                                            </td>
                                            <td data-order="<%= user.isCheckIn ? 1 : 0 %>">
                                                <input type="checkbox" class="checkin-toggle" data-_id="<%= user._id %>" <%= user.isCheckIn ? 'checked' : '' %> />
                                            </td>
                                            <td>
                                                <div class="user-action-buttons">
                                                    <div class="qrcode-container">
                                                        <button type="button" class="btn btn-outline-info qrcode-btn" data-user-id="<%= user._id %>" title="<%= t('users.downloadQrCodeBtn') %>">
                                                            <i class="fa fa-qrcode"></i>
