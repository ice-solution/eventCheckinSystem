                                        <% if (formConfig && formConfig.sections) { %>
                                            <% const sortedSections = [...formConfig.sections].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                                            <% sortedSections.forEach(section => { %>
                                                <% if (section.visible && section.fields) { %>
                                                    <% const sortedFields = [...section.fields].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                                                    <% sortedFields.forEach(field => { %>
                                                        <% if (field.visible) { %>
                                                            <th data-field-name="<%= field.fieldName %>">
                                                                <% 
                                                                let displayLabel = '';
                                                                if (typeof field.label === 'string') {
                                                                    displayLabel = field.label;
                                                                } else if (field.label && field.label[lang]) {
                                                                    displayLabel = field.label[lang];
                                                                } else if (field.label && field.label.zh) {
                                                                    displayLabel = field.label.zh;
                                                                } else {
                                                                    displayLabel = field.fieldName || '';
                                                                }
                                                                %>
                                                                <%= displayLabel %>
                                                            </th>
                                                        <% } %>
                                                    <% }); %>
                                                <% } %>
                                            <% }); %>
