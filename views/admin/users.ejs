                            <!-- Add User Form -->
                            <div id="addUserForm" class="add-user-form" style="display: none; position: relative;">
                                <button type="button" id="cancelAddUser" aria-label="Close" style="position: absolute; top: 20px; right: 20px; background: none; border: none; font-size: 1.4rem; line-height: 1; color: #6c757d; cursor: pointer;">&times;</button>
                                <h5><%= t('users.addUserFormTitle') %></h5>
                                <form id="newUserForm">
                                    <% if (formConfig && formConfig.sections) { %>
                                        <% const addFormSortedSections = [...formConfig.sections].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                                        <% addFormSortedSections.forEach((section, sectionIndex) => { %>
                                            <% if (section.visible && section.fields) { %>
                                                <% const addFormSortedFields = [...section.fields].sort((a, b) => (a.order || 0) - (b.order || 0)); %>
                                                <div class="form-section mb-4">
                                                    <h6>
                                                        <% 
                                                        let sectionTitle = '';
                                                        if (typeof section.sectionTitle === 'string') {
                                                            sectionTitle = section.sectionTitle;
                                                        } else if (section.sectionTitle && section.sectionTitle[lang]) {
                                                            sectionTitle = section.sectionTitle[lang];
                                                        } else if (section.sectionTitle && section.sectionTitle.zh) {
                                                            sectionTitle = section.sectionTitle.zh;
                                                        } else {
                                                            sectionTitle = section.sectionName || '';
                                                        }
                                                        %>
                                                        <%= sectionTitle %>
                                                    </h6>
                                                    <div class="row">
                                                        <% addFormSortedFields.forEach((field, fieldIndex) => { %>
                                                            <% if (field.visible) { %>
                                                                <% const _addUserSelectOther = (field.type === 'select' && field.options && field.options.some(o => o && o.isOther)); %>
                                                                <div class="col-md-6">
                                                                    <div class="form-group">
                                                                        <label for="<%= _addUserSelectOther ? ('newUser_' + field.fieldName + '_sel') : ('newUser' + field.fieldName) %>">
                                                                            <% 
                                                                            let fieldLabel = '';
                                                                            if (typeof field.label === 'string') {
                                                                                fieldLabel = field.label;
                                                                            } else if (field.label && field.label[lang]) {
                                                                                fieldLabel = field.label[lang];
                                                                            } else if (field.label && field.label.zh) {
                                                                                fieldLabel = field.label.zh;
                                                                            } else {
                                                                                fieldLabel = field.fieldName || '';
                                                                            }
                                                                            %>
                                                                            <%= fieldLabel %>
                                                                            <% if (field.required) { %>
                                                                                <span class="text-danger">*</span>
                                                                            <% } %>
                                                                        </label>
                                                                        <% if (field.type === 'select' && field.options) { %>
                                                                            <% if (_addUserSelectOther) { %>
                                                                            <select class="form-control js-select-maybe-other" id="newUser_<%= field.fieldName %>_sel"
                                                                                    data-select-other-base="newUser_<%= field.fieldName %>"
                                                                                    <%= field.required ? 'required' : '' %>>
                                                                                <option value="">--- Please Select ---</option>
                                                                                <% field.options.forEach((option) => { %>
                                                                                    <option value="<%= option.value %>" data-is-other="<%= option.isOther ? '1' : '' %>">
                                                                                        <% 
                                                                                        let optionLabel = '';
                                                                                        if (typeof option.label === 'string') {
                                                                                            optionLabel = option.label;
                                                                                        } else if (option.label && option.label[lang]) {
                                                                                            optionLabel = option.label[lang];
                                                                                        } else if (option.label && option.label.zh) {
                                                                                            optionLabel = option.label.zh;
                                                                                        } else {
                                                                                            optionLabel = option.value || '';
                                                                                        }
                                                                                        %>
                                                                                        <%= optionLabel %>
                                                                                    </option>
                                                                                <% }); %>
                                                                            </select>
                                                                            <input type="text" class="form-control mt-2 d-none js-select-other-text"
                                                                                   id="newUser_<%= field.fieldName %>_other"
                                                                                   placeholder="<%= t('users.pleaseSpecify') %>"
                                                                                   autocomplete="off">
                                                                            <input type="hidden" name="<%= field.fieldName %>" id="newUser_<%= field.fieldName %>_hidden" value="">
                                                                            <% } else { %>
                                                                            <select class="form-control" id="newUser<%= field.fieldName %>" name="<%= field.fieldName %>" <%= field.required ? 'required' : '' %>>
                                                                                <option value="">--- Please Select ---</option>
                                                                                <% field.options.forEach((option) => { %>
                                                                                    <option value="<%= option.value %>">
                                                                                        <% 
                                                                                        let optionLabel = '';
                                                                                        if (typeof option.label === 'string') {
                                                                                            optionLabel = option.label;
                                                                                        } else if (option.label && option.label[lang]) {
                                                                                            optionLabel = option.label[lang];
                                                                                        } else if (option.label && option.label.zh) {
                                                                                            optionLabel = option.label.zh;
                                                                                        } else {
                                                                                            optionLabel = option.value || '';
                                                                                        }
                                                                                        %>
                                                                                        <%= optionLabel %>
                                                                                    </option>
                                                                                <% }); %>
                                                                            </select>
                                                                            <% } %>
                                                                        <% } else if (field.type === 'checkbox' && field.options) { %>
                                                                            <div class="checkbox-group">
                                                                                <% field.options.forEach((option, optionIndex) => { %>
                                                                                    <div class="form-check">
                                                                                        <input class="form-check-input" type="checkbox" 
                                                                                               id="newUser<%= field.fieldName %>_<%= optionIndex %>" 
                                                                                               name="<%= field.fieldName %>[]" 
                                                                                               value="<%= option.value %>">
                                                                                        <label class="form-check-label" for="newUser<%= field.fieldName %>_<%= optionIndex %>">
                                                                                            <% 
                                                                                            let optionLabel = '';
                                                                                            if (typeof option.label === 'string') {
                                                                                                optionLabel = option.label;
                                                                                            } else if (option.label && option.label[lang]) {
                                                                                                optionLabel = option.label[lang];
                                                                                            } else if (option.label && option.label.zh) {
                                                                                                optionLabel = option.label.zh;
                                                                                            } else {
                                                                                                optionLabel = option.value || '';
                                                                                            }
                                                                                            %>
                                                                                            <%= optionLabel %>
                                                                                        </label>
                                                                                    </div>
                                                                                <% }); %>
                                                                            </div>
                                                                        <% } else if (field.type === 'radio' && field.options) { %>
                                                                            <div class="radio-group">
                                                                                <% field.options.forEach((option, optionIndex) => { %>
                                                                                    <div class="form-check">
                                                                                        <input class="form-check-input" type="radio" 
                                                                                               id="newUser<%= field.fieldName %>_<%= optionIndex %>" 
                                                                                               name="<%= field.fieldName %>" 
                                                                                               value="<%= option.value %>"
                                                                                               <%= field.required ? 'required' : '' %>>
                                                                                        <label class="form-check-label" for="newUser<%= field.fieldName %>_<%= optionIndex %>">
                                                                                            <% 
                                                                                            let optionLabel = '';
                                                                                            if (typeof option.label === 'string') {
                                                                                                optionLabel = option.label;
                                                                                            } else if (option.label && option.label[lang]) {
                                                                                                optionLabel = option.label[lang];
                                                                                            } else if (option.label && option.label.zh) {
                                                                                                optionLabel = option.label.zh;
                                                                                            } else {
                                                                                                optionLabel = option.value || '';
                                                                                            }
                                                                                            %>
                                                                                            <%= optionLabel %>
                                                                                        </label>
                                                                                    </div>
                                                                                <% }); %>
                                                                            </div>
                                                                        <% } else if (field.type === 'textarea') { %>
                                                                            <textarea class="form-control" id="newUser<%= field.fieldName %>" name="<%= field.fieldName %>" 
                                                                                      placeholder="<%= (typeof field.placeholder === 'string' ? field.placeholder : (field.placeholder && field.placeholder[lang] ? field.placeholder[lang] : (field.placeholder && field.placeholder.zh ? field.placeholder.zh : ''))) || '' %>" <%= field.required ? 'required' : '' %> rows="3"></textarea>
                                                                        <% } else { %>
                                                                            <input type="<%= field.type %>" class="form-control" id="newUser<%= field.fieldName %>" name="<%= field.fieldName %>" 
                                                                                   placeholder="<%= (typeof field.placeholder === 'string' ? field.placeholder : (field.placeholder && field.placeholder[lang] ? field.placeholder[lang] : (field.placeholder && field.placeholder.zh ? field.placeholder.zh : ''))) || '' %>" <%= field.required ? 'required' : '' %>>
                                                                        <% } %>
                                                                    </div>
                                                                </div>
                                                            <% } %>
                                                        <% }); %>
                                                    </div>
                                                </div>
                                            <% } %>
                                        <% }); %>
                                    <% } else { %>
                                        <!-- 預設表單字段（如果沒有formConfig） -->
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="newUserEmail">Email *</label>
                                                    <input type="email" class="form-control" id="newUserEmail" name="email" required>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="newUserName">Name *</label>
                                                    <input type="text" class="form-control" id="newUserName" name="name" required>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="newUserCompany">Company</label>
                                                    <input type="text" class="form-control" id="newUserCompany" name="company">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="newUserPhone">Phone</label>
                                                    <input type="text" class="form-control" id="newUserPhone" name="phone">
                                                </div>
                                            </div>
                                        </div>
                                    <% } %>
                                    <div class="form-group">
                                        <button type="submit" class="btn btn-success"><i class="fas fa-plus"></i> <%= t('users.addUserBtn') %></button>
                                    </div>
                                </form>
                            </div>

