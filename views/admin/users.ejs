                    error: function(xhr, status, error) {
                        showAlert('danger', _US.deleteUserFailed);
                    }
                });
            }
        });

        // Use event delegation to listen for checkbox changes
        $('#usersTable tbody').on('change', '.checkin-toggle', function() {
            const row = $(this).closest('tr');
