                                                    const agreementDate = new Date(user.agreementRecordedAt);
                                                    if (!isNaN(agreementDate.getTime())) { %>
                                                    <%= agreementDate.toLocaleString('zh-TW', {
                                                        timeZone: 'Asia/Hong_Kong',
                                                        year: 'numeric',
                                                        month: '2-digit',
                                                        day: '2-digit',
                                                        hour: '2-digit',
                                                        minute: '2-digit',
                                                        second: '2-digit',
                                                        hour12: false
                                                    }) %>
                                                <% } else { %>-<% }
                                                } else { %>-<% } %>
                                            </td>
                                            <% } %>
                                            <td data-order="<%= (user.create_at || user.created_at) ? new Date(user.create_at || user.created_at).getTime() : 0 %>">
                                                <% 
