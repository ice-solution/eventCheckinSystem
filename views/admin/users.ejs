    emailTypeInvoice: '<%= t("users.emailTypeInvoice") %>',
    emailTypePaymentReceipt: '<%= t("users.emailTypePaymentReceipt") %>',
    conditionLabel: '<%= t("users.condition") %>',
    useDefaultTemplate: '<%= t("users.useDefaultTemplate") %>',
    confirmSend: '<%= t("users.confirmSend") %>',
    sending: '<%= t("users.sending") %>',
    batchDeleteSelected: '<%= t("users.batchDeleteSelected") %>',
    batchSendEmailSelected: '<%= t("users.batchSendEmailSelected") %>',
    batchSendSmsSelected: '<%= t("users.batchSendSmsSelected") %>',
    processing: '<%= t("users.processing") %>',
    errorNoFieldName: '<%= t("users.errorNoFieldName") %>',
    errorNoUserId: '<%= t("users.errorNoUserId") %>',
    modalNotFound: '<%= t("users.modalNotFound") %>',
    missingResendInfo: '<%= t("users.missingResendInfo") %>',
    eventTemplateLabel: '<%= t("users.eventTemplateLabel") %>',
    globalTemplateLabel: '<%= t("users.globalTemplateLabel") %>',
    batchEmailFailed: '<%= t("users.batchEmailFailed") %>',
    emailSettingsTitle: '<%= t("users.emailSettingsTitle") %>',
    saveEmailSettings: '<%= t("users.saveEmailSettings") %>',
    viewQrCode: '<%= t("users.viewQrCode") %>',
    deleteBtn: '<%= t("users.deleteBtn") %>',
    smsSentSuccess: '<%= t("users.smsSentSuccess") %>',
    fieldRequired: '<%= t("users.fieldRequired") %>',
    noNameProvided: '<%= t("users.noNameProvided") %>',
    batchEmailSummaryTitle: '<%= t("users.batchEmailSummaryTitle") %>',
    emailTypeResultLabel: '<%= t("users.emailTypeResultLabel") %>',
    successLabel: '<%= t("users.successLabel") %>',
    failedLabel: '<%= t("users.failedLabel") %>',
    skippedLabel: '<%= t("users.skippedLabel") %>',
    totalLabel: '<%= t("users.totalLabel") %>',
    detailsLabel: '<%= t("users.detailsLabel") %>',
    detailedRecordsTitle: '<%= t("users.detailedRecordsTitle") %>',
    nameColLabel: '<%= t("users.nameColLabel") %>',
    emailColLabel: '<%= t("users.emailColLabel") %>',
    statusColLabel: '<%= t("users.statusColLabel") %>',
    phoneColLabel: '<%= t("users.phoneColLabel") %>',
    welcomeMethodLabel: '<%= t("users.welcomeMethodLabel") %>',
    methodEmail: '<%= t("users.methodEmail") %>',
    methodSms: '<%= t("users.methodSms") %>',
    methodBoth: '<%= t("users.methodBoth") %>',
    sendWelcomeEmailLabel: '<%= t("users.sendWelcomeEmailLabel") %>',
    sendConfirmationEmailLabel: '<%= t("users.sendConfirmationEmailLabel") %>',
    sendReminderEmailLabel: '<%= t("users.sendReminderEmailLabel") %>',
    sendThankYouEmailLabel: '<%= t("users.sendThankYouEmailLabel") %>',
    manageSmsTemplates: '<%= t("users.manageSmsTemplates") %>',
    closeBtn: '<%= t("users.closeBtn") %>'
};

    $(document).ready(function() {
        // 將 modal 移到 body 最外層，避免被父元素 overflow 或 stacking context 遮擋
        $('#batchSendEmailModal, #batchSendSmsModal, #resendEmailModal, #batchSendSmsResultsModal, #batchSendEmailResultsModal').appendTo('body');
        
        // Check if DataTables is loaded
        if (typeof $.fn.DataTable === 'undefined') {
            console.error('DataTables is not loaded!');
            alert('DataTables plugin is not loaded. Please refresh the page.');
            return;
        }
        
        // Store all user IDs for select all functionality
        const allUserIds = [];
        <% event.users.forEach(user => { %>
            allUserIds.push('<%= user._id %>');
        <% }); %>

        // Global set to track selected user IDs across all pages
        const selectedUserIds = new Set();

        // Initialize DataTable with inline editing
        // Calculate the Created At column index dynamically
        const totalColumns = $('#usersTable thead th').length;
        const createdAtColumnIndex = totalColumns - 3;

        const table = $('#usersTable').DataTable({
            pageLength: 50,
            dom: 'rtip',
            autoWidth: true,
            columnDefs: [
                {
                    targets: 0,
                    orderable: false,
                    searchable: false
                },
                {
                    targets: createdAtColumnIndex,
                    type: 'num',
                    orderable: true,
                    searchable: false
                },
                {
                    targets: -2,
                    type: 'num',
                    orderable: true,
                    searchable: false,
                    render: function(data, type, row, meta) {
                        if (type === 'sort' || type === 'type') {
                            const tr = meta.settings.aoData[meta.row].nTr;
                            const td = tr && tr.cells ? tr.cells[meta.col] : null;
                            const v = td ? td.getAttribute('data-order') : null;
                            return v !== null && v !== '' ? parseInt(v, 10) : 0;
                        }
                        return data;
                    }
                },
                {
                    targets: -1,
                    orderable: false,
                    searchable: false
                }
            ],
            order: [[createdAtColumnIndex, 'desc']],
            initComplete: function() {
                if (!$('#usersTable').parent().hasClass('users-table-xscroll')) {
                    $('#usersTable').wrap('<div class="users-table-xscroll"></div>');
                }
                fixPaginationArrows();
            },
            drawCallback: function() {
                // Restore checkbox states after table redraw
                $('.user-select').each(function() {
                    const userId = $(this).data('_id');
                    if (selectedUserIds.has(userId)) {
                        $(this).prop('checked', true);
                    }
                });
                updateSelectAllCheckbox();
                updateBatchDeleteButton();
                updateBatchSendEmailButton();
                updateBatchSendSmsButton();
                // Restore arrow icons after each draw
                fixPaginationArrows();
            }
        });

        function fixPaginationArrows() {
            $('#usersTable_wrapper .paginate_button.previous a').html('&#8249;');
            $('#usersTable_wrapper .paginate_button.next a').html('&#8250;');
            // Force no background on prev/next via inline style (overrides Bootstrap)
            $('#usersTable_wrapper .page-item.previous .page-link, #usersTable_wrapper .page-item.next .page-link')
                .css({ 'background-color': 'transparent', 'background': 'transparent', 'border-color': 'transparent' })
                .off('mouseenter.pgNav mouseleave.pgNav')
                .on('mouseenter.pgNav', function() {
                    $(this).css({ 'background-color': 'transparent', 'background': 'transparent' });
                })
                .on('mouseleave.pgNav', function() {
                    $(this).css({ 'background-color': 'transparent', 'background': 'transparent' });
                });
        }

        // 欄位顯示切換（暫時生效，重新整理後回復）
        function initColumnToggles() {
            const $list = $('#columnToggleList');
            $list.empty();
            $('#usersTable thead th').each(function(idx) {
                const headerText = ($(this).text() || '').trim() || ('Column ' + (idx + 1));
                const isProtected = idx === 0 || idx === (totalColumns - 1); // 勾選欄、Actions 欄不提供隱藏
                if (isProtected) return;
                const checked = table.column(idx).visible();
                const safeLabel = $('<div>').text(headerText).html();
                const itemHtml =
                    '<label class="column-toggle-item">' +
                        '<input type="checkbox" class="column-toggle-checkbox" data-col-index="' + idx + '" ' + (checked ? 'checked' : '') + '>' +
                        '<span>' + safeLabel + '</span>' +
                    '</label>';
                $list.append(itemHtml);
            });
        }

        $(document).on('change', '.column-toggle-checkbox', function() {
            const colIndex = parseInt($(this).attr('data-col-index'), 10);
            const shouldShow = $(this).is(':checked');
            if (!Number.isNaN(colIndex)) {
                table.column(colIndex).visible(shouldShow, false);
                table.columns.adjust().draw(false);
            }
        });

        // Column toggle gear button - show modal panel
        $('#columnToggleBtn').off('click').on('click', function(e) {
            e.stopPropagation();
            const $panel = $('#columnTogglePanel');
            if ($panel.css('display') === 'none') {
                $panel.css('display', 'flex').css('flex-direction', 'column');
            } else {
                $panel.css('display', 'none');
            }
        });

        // Close panel when clicking outside
