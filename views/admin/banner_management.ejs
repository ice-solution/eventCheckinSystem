<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'zh-Hant' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('banner_management.title') %> - <%= event.name %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .container {
            max-width: 1000px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            padding: 30px;
            margin-top: 30px;
            margin-bottom: 30px;
        }
        .page-header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e9ecef;
        }
        .page-header h1 {
            color: #2c3e50;
            font-weight: 600;
            margin-bottom: 10px;
        }
        .banner-preview {
            text-align: center;
            margin: 30px 0;
            padding: 20px;
            border: 2px dashed #dee2e6;
            border-radius: 10px;
            background-color: #f8f9fa;
        }
        .banner-preview img {
            max-width: 100%;
            max-height: 300px;
            border-radius: 5px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .upload-section {
            background-color: #f8f9fa;
            padding: 30px;
            border-radius: 10px;
            margin: 20px 0;
        }
        .file-upload {
            border: 2px dashed #007bff;
            border-radius: 10px;
            padding: 40px;
            text-align: center;
            background-color: white;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .file-upload:hover {
            border-color: #0056b3;
            background-color: #f8f9fa;
        }
        .file-upload.dragover {
            border-color: #28a745;
            background-color: #d4edda;
        }
        .file-input {
            display: none;
        }
        .upload-icon {
            font-size: 3rem;
            color: #007bff;
            margin-bottom: 15px;
        }
        .btn {
            padding: 12px 30px;
            font-weight: 500;
            border-radius: 5px;
            margin: 5px;
        }
        .alert {
            border-radius: 5px;
            margin: 20px 0;
        }
        .info-box {
            background-color: #e3f2fd;
            border-left: 4px solid #2196f3;
            padding: 15px;
            margin: 20px 0;
            border-radius: 0 5px 5px 0;
        }
        .back-btn {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="back-btn">
            <a href="/events/<%= event._id %>" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> <%= t('banner_management.backBtn') %>
            </a>
        </div>

        <div class="page-header">
            <h1><i class="fas fa-image"></i> <%= t('banner_management.heading') %></h1>
            <p class="text-muted"><%= t('banner_management.subtitle') %></p>
        </div>

        <% if (message) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> <%= message %>
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle"></i> <%= error %>
                <button type="button" class="close" data-dismiss="alert">
                    <span>&times;</span>
                </button>
            </div>
        <% } %>

        <div class="info-box">
            <h5><i class="fas fa-info-circle"></i> <%= t('banner_management.infoTitle') %></h5>
            <ul class="mb-0">
                <li><%= t('banner_management.info1') %></li>
                <li><%= t('banner_management.info2') %></li>
                <li><%= t('banner_management.info3') %></li>
                <li><%= t('banner_management.info4') %></li>
            </ul>
        </div>

        <% if (currentBanner) { %>
            <div class="banner-preview">
                <h4><i class="fas fa-eye"></i> <%= t('banner_management.currentPreviewTitle') %></h4>
                <img src="<%= currentBanner %>" alt="Current Banner" class="img-fluid">
                <div class="mt-3">
                    <form action="/events/<%= event._id %>/banner/delete" method="POST"
                          onsubmit="return confirm('<%= t('banner_management.deleteBannerConfirm') %>')" style="display: inline;">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> <%= t('banner_management.deleteBannerBtn') %>
                        </button>
                    </form>
                </div>
            </div>
        <% } else { %>
            <div class="banner-preview">
                <h4><i class="fas fa-exclamation-triangle"></i> <%= t('banner_management.noBannerTitle') %></h4>
                <p class="text-muted"><%= t('banner_management.noBannerHint') %></p>
            </div>
        <% } %>

        <div class="upload-section">
            <h4><i class="fas fa-upload"></i> <%= t('banner_management.uploadTitle') %></h4>
            <form action="/events/<%= event._id %>/banner/upload" method="POST" enctype="multipart/form-data" id="uploadForm">
                <div class="file-upload" id="fileUpload">
                    <div class="upload-icon">
                        <i class="fas fa-cloud-upload-alt"></i>
                    </div>
                    <h5><%= t('banner_management.uploadHint') %></h5>
                    <p class="text-muted"><%= t('banner_management.uploadFormatHint') %></p>
                    <input type="file" name="banner" id="bannerFile" class="file-input" accept="image/png,image/jpeg,image/jpg" required>
                    <button type="button" class="btn btn-outline-primary" id="selectFileBtn">
                        <i class="fas fa-folder-open"></i> <%= t('banner_management.selectFileBtn') %>
                    </button>
                </div>

                <div id="fileInfo" class="mt-3" style="display: none;">
                    <div class="alert alert-info">
                        <i class="fas fa-file-image"></i>
                        <strong><%= t('banner_management.selectedFileLabel') %></strong> <span id="fileName"></span>
                        <br>
                        <strong><%= t('banner_management.fileSizeLabel') %></strong> <span id="fileSize"></span>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary" id="uploadBtn" disabled>
                        <i class="fas fa-upload"></i> <%= t('banner_management.uploadBtn') %>
                    </button>
                    <button type="reset" class="btn btn-secondary" onclick="resetForm()">
                        <i class="fas fa-undo"></i> <%= t('banner_management.resetBtn') %>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
        const _BM = {
            typeAlert: '<%= t("banner_management.typeAlert") %>',
            sizeAlert: '<%= t("banner_management.sizeAlert") %>',
            noFileAlert: '<%= t("banner_management.noFileAlert") %>',
            uploadingBtn: '<i class="fas fa-spinner fa-spin"></i> <%= t("banner_management.uploadingBtn") %>'
        };

        document.addEventListener('DOMContentLoaded', function() {
            const fileUpload = document.getElementById('fileUpload');
            const selectFileBtn = document.getElementById('selectFileBtn');
            const bannerFile = document.getElementById('bannerFile');

            let isSelectingFile = false;

            function selectFile() {
                if (isSelectingFile) return;
                isSelectingFile = true;
                bannerFile.click();
                setTimeout(() => { isSelectingFile = false; }, 100);
            }

            bannerFile.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const allowedTypes = ['image/png', 'image/jpeg', 'image/jpg'];
                    if (!allowedTypes.includes(file.type)) {
                        alert(_BM.typeAlert);
                        resetForm();
                        return;
                    }

                    const maxSize = 5 * 1024 * 1024;
                    if (file.size > maxSize) {
                        alert(_BM.sizeAlert);
                        resetForm();
                        return;
                    }

                    document.getElementById('fileName').textContent = file.name;
                    document.getElementById('fileSize').textContent = formatFileSize(file.size);
                    document.getElementById('fileInfo').style.display = 'block';
                    document.getElementById('uploadBtn').disabled = false;

                    fileUpload.style.borderColor = '#28a745';
                    fileUpload.style.backgroundColor = '#d4edda';
                }
            });

            fileUpload.addEventListener('dragover', function(e) {
                e.preventDefault();
                this.classList.add('dragover');
            });

            fileUpload.addEventListener('dragleave', function(e) {
                e.preventDefault();
                this.classList.remove('dragover');
            });

            fileUpload.addEventListener('drop', function(e) {
                e.preventDefault();
                this.classList.remove('dragover');
                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    bannerFile.files = files;
                    bannerFile.dispatchEvent(new Event('change'));
                }
            });

            selectFileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                selectFile();
            });

            fileUpload.addEventListener('click', function(e) {
                if (e.target.closest('#selectFileBtn')) return;
                selectFile();
            });

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            window.resetForm = function() {
                document.getElementById('uploadForm').reset();
                document.getElementById('fileInfo').style.display = 'none';
                document.getElementById('uploadBtn').disabled = true;
                fileUpload.style.borderColor = '#007bff';
                fileUpload.style.backgroundColor = 'white';
            };

            document.getElementById('uploadForm').addEventListener('submit', function(e) {
                const file = bannerFile.files[0];
                if (!file) {
                    e.preventDefault();
                    alert(_BM.noFileAlert);
                    return;
                }

                const uploadBtn = document.getElementById('uploadBtn');
                uploadBtn.innerHTML = _BM.uploadingBtn;
                uploadBtn.disabled = true;

                const form = this;
                form.removeEventListener('submit', arguments.callee);
            });
        });
    </script>
</body>
</html>
