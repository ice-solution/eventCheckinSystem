<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'zh-Hant' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= t('awards_admin.pageTitle') %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <h1><%= t('awards_admin.heading') %></h1>
        <div class="form-group">
            <label for="numOfUsers"><%= t('awards_admin.numUsersLabel') %></label>
            <input type="number" class="form-control" id="numOfUsers" min="1" required>
        </div>
        <button id="startDraw" class="btn btn-primary"><%= t('awards_admin.startDraw') %></button>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        document.getElementById('startDraw').onclick = function() {
            const numOfUsers = document.getElementById('numOfUsers').value;
            socket.emit('start_draw', numOfUsers);
        };
    </script>
</body>
</html>
