<%- include("components/header") %>
<%- include("components/menu", { eventId: eventId }) %>
<%- include("components/responsive_layout_style") %>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">

<div id="right-panel" class="right-panel">
    <%- include("components/rightpanel_header") %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('luckydraw_setting.title') %></strong>
                        </div>
                        <div class="card-body">
                            <form id="uploadForm" enctype="multipart/form-data" action="/events/<%= eventId %>/luckydraw_setting/upload-background" method="POST">
                                <div class="form-group">
                                    <label for="backgroundImage"><%= t('luckydraw_setting.uploadLabel') %></label>
                                    <input type="file" id="backgroundImage" name="backgroundImage" accept=".jpg, .jpeg" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><i class="fa fa-upload mr-1"></i><%= t('luckydraw_setting.uploadBtn') %></button>
                            </form>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-header">
                            <strong class="card-title"><%= t('luckydraw_setting.awardPasswordTitle') %></strong>
                        </div>
                        <div class="card-body">
                            <p class="text-muted small"><%= t('luckydraw_setting.awardPasswordDesc') %> (<code>/events/<%= eventId %>/luckydraw/award</code>)</p>
                            <% if (typeof awardPasswordSet !== 'undefined' && awardPasswordSet) { %>
                                <p class="text-success small mb-2"><%= t('luckydraw_setting.passwordSet') %></p>
                            <% } %>
                            <div class="form-group">
                                <label for="awardPassword"><%= t('luckydraw_setting.passwordLabel') %></label>
                                <input type="password" id="awardPassword" class="form-control" placeholder="<%= t('luckydraw_setting.noPasswordPlaceholder') %>" autocomplete="new-password">
                            </div>
                            <button type="button" id="saveAwardPasswordBtn" class="btn btn-primary"><i class="fa fa-save mr-1"></i><%= t('common.save') %></button>
                            <span id="awardPasswordMsg" class="ml-2 small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('luckydraw_setting.previewTitle') %></strong>
                        </div>
                        <div class="card-body text-center">
                            <img id="backgroundPreview" src="/luckydraw/img/<%= eventId %>.jpg" alt="Background preview" style="max-width: 100%; height: auto;">
                            <div id="noImageMessage" style="display: none;"><%= t('luckydraw_setting.noImage') %></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include("components/footer") %>
<script>
    window.onload = function() {
        const img = document.getElementById('backgroundPreview');
        const noImageMessage = document.getElementById('noImageMessage');
        img.onload = function() { noImageMessage.style.display = 'none'; };
        img.onerror = function() { img.style.display = 'none'; noImageMessage.style.display = 'block'; };
    };

    document.getElementById('saveAwardPasswordBtn').addEventListener('click', function() {
        const eventId = '<%= eventId %>';
        const password = document.getElementById('awardPassword').value.trim();
        const btn = this;
        const msg = document.getElementById('awardPasswordMsg');
        btn.disabled = true;
        msg.textContent = '';
        fetch('/events/' + eventId + '/luckydraw_setting/award-password', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: password })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            msg.textContent = password ? '<%= t("luckydraw_setting.saved") %>' : '<%= t("luckydraw_setting.savedNoPassword") %>';
            msg.className = 'ml-2 small text-success';
        })
        .catch(function() {
            msg.textContent = '<%= t("luckydraw_setting.saveFailed") %>';
            msg.className = 'ml-2 small text-danger';
        })
        .finally(function() { btn.disabled = false; });
    });
</script>
