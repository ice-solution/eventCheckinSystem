<%- include ("components/header") %>
<%- include ("components/menu", {eventId: ''})  %>
<link rel="stylesheet" href="/admin/assets/css/cs-skin-elastic.css">
<link rel="stylesheet" href="/admin/assets/css/lib/datatable/dataTables.bootstrap.min.css">
<link rel="stylesheet" href="/admin/assets/css/style.css">
<div id="right-panel" class="right-panel">
    <%- include ("components/rightpanel_header", { backUrl: '/events/list' }) %>
    <div class="content">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <strong class="card-title"><%= t('create_event.title') %></strong>
                        </div>
                        <div class="card-body">
                            <form id="createEventForm">
                                <div class="form-group">
                                    <label for="name"><%= t('create_event.eventName') %></label>
                                    <input type="text" class="form-control" id="name" required>
                                </div>
                                <div class="form-group">
                                    <label for="from"><%= t('create_event.startTime') %></label>
                                    <input type="datetime-local" class="form-control" id="from" required>
                                </div>
                                <div class="form-group">
                                    <label for="to"><%= t('create_event.endTime') %></label>
                                    <input type="datetime-local" class="form-control" id="to" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><%= t('create_event.submit') %></button>
                            </form>
                            <div id="alertContainer" class="mt-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    var successMsg = <%- JSON.stringify(t('create_event.successMsg')) %>;
    var errorMsg = <%- JSON.stringify(t('create_event.errorMsg')) %>;
    var timeRangeError = <%- JSON.stringify(lang === 'en' ? 'End time must be after start time.' : '結束時間必須晚於開始時間。') %>;

    function escapeHtml(str) {
        return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function showAlert(type, message) {
        var container = document.getElementById('alertContainer');
        if (!container) return;
        container.innerHTML =
            '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
            escapeHtml(message) +
            '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
            '<span aria-hidden="true">&times;</span></button></div>';
    }

    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('createEventForm');
        if (!form) return;

        form.addEventListener('submit', function(e) {
            e.preventDefault();

            var nameInput = document.getElementById('name');
            var fromInput = document.getElementById('from');
            var toInput = document.getElementById('to');
            var submitBtn = form.querySelector('button[type="submit"]');

            var name = (nameInput && nameInput.value || '').trim();
            var from = fromInput ? fromInput.value : '';
            var to = toInput ? toInput.value : '';

            if (!name || !from || !to) {
                showAlert('danger', errorMsg);
                return;
            }
            if (new Date(from).getTime() >= new Date(to).getTime()) {
                showAlert('danger', timeRangeError);
                return;
            }

            if (submitBtn) submitBtn.disabled = true;

            fetch('/events/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: name, from: from, to: to }),
                credentials: 'same-origin'
            }).then(function(res) {
                return res.json().then(function(data) {
                    if (!res.ok) throw new Error((data && data.message) || errorMsg);
                    showAlert('success', successMsg);
                    setTimeout(function() {
                        window.location.href = '/events/list';
                    }, 1500);
                });
            }).catch(function(err) {
                showAlert('danger', err.message || errorMsg);
                if (submitBtn) submitBtn.disabled = false;
            });
        });
    });
})();
</script>
<%- include ("components/footer") %>
