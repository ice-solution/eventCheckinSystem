<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= event && event.name ? event.name : 'Event' %> - 登記</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .container {
            max-width: 800px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            padding: 30px;
            margin-top: 30px;
            margin-bottom: 30px;
        }
        .form-header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e9ecef;
        }
        .form-header h1 {
            color: #2c3e50;
            font-weight: 600;
            margin-bottom: 10px;
            text-align: center;
            overflow-wrap: anywhere;
            word-break: break-word;
            hyphens: auto;
        }
        .form-section {
            margin-bottom: 30px;
        }
        .form-section h3 {
            color: #34495e;
            font-size: 1.3rem;
            margin-bottom: 20px;
            font-weight: 600;
        }

        .language-switcher .btn-group .btn {
            padding: 8px 16px;
            font-size: 14px;
            border-radius: 4px;
        }

        .language-switcher .btn-group .btn.active {
            background-color: #007bff;
            border-color: #007bff;
            color: white;
        }

        .language-switcher .btn-group .btn:not(.active) {
            background-color: transparent;
            border-color: #007bff;
            color: #007bff;
        }

        .language-switcher .btn-group .btn:not(.active):hover {
            background-color: #007bff;
            color: white;
        }
        .form-note {
            background-color: #e3f2fd;
            border-left: 4px solid #2196f3;
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 0 5px 5px 0;
            font-size: 0.9rem;
            color: #1565c0;
        }
        .form-row {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            padding: 10px 0;
            border-bottom: 1px solid #f1f3f4;
        }
        .form-label {
            flex: 0 0 200px;
            font-weight: 600;
            color: #2c3e50;
            padding-right: 20px;
            text-align: right;
        }
        .form-input {
            flex: 1;
            max-width: 400px;
        }
        .required {
            color: #e74c3c;
            margin-left: 3px;
        }
        .form-control {
            border: 2px solid #e9ecef;
            border-radius: 5px;
            /* padding: 10px 15px; */
            font-size: 0.95rem;
            transition: border-color 0.3s ease;
        }
        .form-control:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
        }
        .btn-container {
            text-align: center;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid #e9ecef;
        }
        .btn {
            padding: 12px 30px;
            font-weight: 500;
            border-radius: 5px;
            margin: 0 10px;
            min-width: 120px;
        }
        .btn-primary {
            background-color: #3498db;
            border-color: #3498db;
        }
        .btn-primary:hover {
            background-color: #2980b9;
            border-color: #2980b9;
        }
        .btn-secondary {
            background-color: #95a5a6;
            border-color: #95a5a6;
        }
        .btn-secondary:hover {
            background-color: #7f8c8d;
            border-color: #7f8c8d;
        }
        .alert {
            border-radius: 5px;
            margin-top: 20px;
        }
        .terms-header {
            display: flex;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 16px;
        }
        .terms-header .section-title {
            margin-bottom: 0;
        }
        .terms-open-link {
            font-size: 1rem;
            font-weight: 500;
            color: #3498db;
            text-decoration: underline;
            cursor: pointer;
        }
        .terms-open-link:hover {
            color: #2980b9;
        }
        .terms-agree-row.form-check {
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
            text-align: left;
            padding-left: 0 !important;
            margin-left: 0;
            margin-bottom: 0;
        }
        .terms-agree-row .form-check-input {
            position: static;
            margin-left: 0;
            margin-top: 0.2rem;
            flex-shrink: 0;
        }
        .terms-agree-row .form-check-label {
            padding-left: 0;
            margin-left: 0;
            line-height: 1.5;
        }
        .terms-overlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 2000;
            background: rgba(0, 0, 0, 0.55);
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .terms-overlay.is-open {
            display: flex;
        }
        .terms-modal {
            background: #fff;
            width: 100%;
            max-width: 720px;
            max-height: 85vh;
            border-radius: 10px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .terms-modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid #e9ecef;
        }
        .terms-modal-header h4 {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 600;
            color: #2c3e50;
        }
        .terms-modal-close {
            border: none;
            background: transparent;
            font-size: 1.75rem;
            line-height: 1;
            color: #6c757d;
            cursor: pointer;
            padding: 0 4px;
        }
        .terms-modal-close:hover {
            color: #2c3e50;
        }
        .terms-modal-body {
            margin: 16px 20px 20px;
            padding: 16px;
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            overflow-y: auto;
            max-height: calc(85vh - 120px);
            color: #2c3e50;
            line-height: 1.6;
        }
        .terms-modal-body p {
            margin-bottom: 0.75rem;
        }
        .terms-modal-body ul,
        .terms-modal-body ol {
            margin-bottom: 0.75rem;
            padding-left: 1.25rem;
        }
        @media (max-width: 768px) {
            .form-header h1 {
                font-size: 70%;
            }
            .form-row {
                flex-direction: column;
                align-items: flex-start;
            }
            .form-label {
                flex: none;
                width: 100%;
                text-align: left;
                margin-bottom: 8px;
                padding-right: 0;
            }
            .form-input {
                width: 100%;
                max-width: none;
            }
            /* responsive：按鈕縮小約 30% */
            .btn {
                padding: 8px 20px;
                min-width: 84px;
                font-size: 0.85rem;
                margin: 0 6px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 輪播 -->
        <div id="carouselExampleCaptions" class="carousel slide" data-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="<%= typeof eventBannerSrc !== 'undefined' ? eventBannerSrc : '/exvent/' + event_id + '.jpg' %>" class="d-block w-100" alt="第一張圖片" 
                         onerror="this.onerror=null;this.src='<%= typeof fallbackBannerSrc !== 'undefined' ? fallbackBannerSrc : '/exvent/banner.jpg' %>'">
                    <div class="carousel-caption d-none d-md-block">
                        
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 語言切換 -->
        <div class="language-switcher" style="text-align: right; margin-top: 40px; margin-bottom: 30px;">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-primary" id="langZhBtn" onclick="switchLanguage('zh')">中文</button>
                <button type="button" class="btn btn-outline-primary" id="langEnBtn" onclick="switchLanguage('en')">English</button>
            </div>
        </div>

        <div class="form-header">
            <br><br>
            <h1 id="formTitle"><%= event && event.name ? event.name : 'Event' %></h1>
            <p class="text-muted" id="formSubtitle">請填寫以下資料完成活動報名</p>
        </div>

        <form id="userForm" method="POST">
            <% if (formConfig && formConfig.sections && formConfig.sections.length > 0) { %>
                <% 
                // 根據 order 排序 sections
                const sortedSections = formConfig.sections.slice().sort((a, b) => {
                    const orderA = a.order || 0;
                    const orderB = b.order || 0;
                    return orderA - orderB;
                });
                %>
                <% sortedSections.forEach((section, sectionIndex) => { %>
                    <% if (section.visible) { %>
                        <div class="form-section">
                            <h3 class="section-title" data-zh="<%= section.sectionTitle && section.sectionTitle.zh ? section.sectionTitle.zh : section.sectionTitle %>" data-en="<%= section.sectionTitle && section.sectionTitle.en ? section.sectionTitle.en : '' %>">
                                <%= section.sectionTitle && section.sectionTitle.zh ? section.sectionTitle.zh : (typeof section.sectionTitle === 'string' ? section.sectionTitle : '') %>
                            </h3>
                            
                            <% if (section.fields && section.fields.length > 0) { %>
                                <% 
                                // 根據 order 排序 fields
                                const sortedFields = section.fields.slice().sort((a, b) => {
                                    const orderA = a.order || 0;
                                    const orderB = b.order || 0;
                                    return orderA - orderB;
                                });
                                %>
                                <% sortedFields.forEach((field, fieldIndex) => { %>
                                    <% const fieldDisplayed = field.display !== undefined ? field.display : field.visible !== false; %>
                                    <% if (fieldDisplayed) { %>
                                        <% var _selectHasOther = (field.type === 'select' && field.options && field.options.some(function (o) { return o && o.isOther; })); %>
                                        <% var _fieldControlId = (field.type === 'select' && _selectHasOther) ? (field.fieldName + '_sel') : field.fieldName; %>
                                        <div class="form-row">
                                            <label class="form-label field-label" for="<%= _fieldControlId %>" 
                                                   data-zh="<%= field.label && field.label.zh ? field.label.zh : (typeof field.label === 'string' ? field.label : '') %>" 
                                                   data-en="<%= field.label && field.label.en ? field.label.en : '' %>">
                                                <%= field.label && field.label.zh ? field.label.zh : (typeof field.label === 'string' ? field.label : '') %>
                                                <% if (field.required) { %>
                                                    <span class="required">*</span>
                                                <% } %>
                                            </label>
                                            <div class="form-input">
                                                <!-- Debug: field.type = <%= field.type %>, has options = <%= field.options ? 'yes' : 'no' %> -->
                                                <% if (field.type === 'select' && field.options) { %>
                                                    <% if (_selectHasOther) { %>
                                                        <select class="form-control js-select-maybe-other" id="<%= field.fieldName %>_sel"
                                                                data-select-other-base="<%= field.fieldName %>"
                                                                <%= field.required ? 'required' : '' %>>
                                                            <option value="" class="select-placeholder" data-zh="--- 請選擇 ---" data-en="--- Please select ---">--- 請選擇 ---</option>
                                                            <% field.options.forEach((option) => { %>
                                                                <option value="<%= option.value %>"
                                                                        data-is-other="<%= option.isOther ? '1' : '' %>"
                                                                        data-zh="<%= option.label && option.label.zh ? option.label.zh : option.label %>" 
                                                                        data-en="<%= option.label && option.label.en ? option.label.en : '' %>">
                                                                    <%= option.label && option.label.zh ? option.label.zh : (typeof option.label === 'string' ? option.label : '') %>
                                                                </option>
                                                            <% }); %>
                                                        </select>
                                                        <input type="text" class="form-control mt-2 d-none js-select-other-text"
                                                               id="<%= field.fieldName %>_other"
                                                               data-placeholder-zh="請填寫"
                                                               data-placeholder-en="Please specify"
                                                               autocomplete="off">
                                                        <input type="hidden" name="<%= field.fieldName %>" id="<%= field.fieldName %>_hidden" value="">
                                                    <% } else { %>
                                                        <select class="form-control" id="<%= field.fieldName %>" name="<%= field.fieldName %>" <%= field.required ? 'required' : '' %>>
                                                            <option value="" class="select-placeholder" data-zh="--- 請選擇 ---" data-en="--- Please select ---">--- 請選擇 ---</option>
                                                            <% field.options.forEach((option) => { %>
                                                                <option value="<%= option.value %>" 
                                                                        data-zh="<%= option.label && option.label.zh ? option.label.zh : option.label %>" 
                                                                        data-en="<%= option.label && option.label.en ? option.label.en : '' %>">
                                                                    <%= option.label && option.label.zh ? option.label.zh : (typeof option.label === 'string' ? option.label : '') %>
                                                                </option>
                                                            <% }); %>
                                                        </select>
                                                    <% } %>
                                                <% } else if (field.type === 'checkbox' && field.options) { %>
                                                    <div class="checkbox-group" id="<%= field.fieldName %>-group">
                                                        <% field.options.forEach((option, optionIndex) => { %>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" 
                                                                       id="<%= field.fieldName %>_<%= optionIndex %>" 
                                                                       name="<%= field.fieldName %>[]" 
                                                                       value="<%= option.value %>"
                                                                       data-zh="<%= option.label && option.label.zh ? option.label.zh : option.label %>" 
                                                                       data-en="<%= option.label && option.label.en ? option.label.en : '' %>"
                                                                       <%= field.required ? 'data-required="true"' : '' %>>
                                                                <label class="form-check-label" for="<%= field.fieldName %>_<%= optionIndex %>"
                                                                       data-zh="<%= option.label && option.label.zh ? option.label.zh : (typeof option.label === 'string' ? option.label : '') %>" 
                                                                       data-en="<%= option.label && option.label.en ? option.label.en : '' %>">
                                                                    <%= option.label && option.label.zh ? option.label.zh : (typeof option.label === 'string' ? option.label : '') %>
                                                                </label>
                                                            </div>
                                                        <% }); %>
                                                    </div>
                                                    <% if (field.required) { %>
                                                        <script>
                                                            // 驗證至少選擇一個 checkbox
                                                            (function() {
                                                                const checkboxes = document.querySelectorAll('#<%= field.fieldName %>-group input[type="checkbox"]');
                                                                const group = document.getElementById('<%= field.fieldName %>-group');
                                                                
                                                                function validateCheckboxGroup() {
                                                                    const checked = Array.from(checkboxes).some(cb => cb.checked);
                                                                    const currentLang = typeof currentLanguage !== 'undefined' ? currentLanguage : 'zh';
                                                                    const fieldLabelZh = '<%= field.label && field.label.zh ? field.label.zh : (typeof field.label === "string" ? field.label : "") %>';
                                                                    const fieldLabelEn = '<%= field.label && field.label.en ? field.label.en : "" %>';
                                                                    
                                                                    if (!checked) {
                                                                        if (currentLang === 'en' && fieldLabelEn) {
                                                                            group.setCustomValidity('Please select at least one option for ' + fieldLabelEn + '.');
                                                                        } else {
                                                                            group.setCustomValidity(fieldLabelZh + ' 為必填欄位');
                                                                        }
                                                                    } else {
                                                                        group.setCustomValidity('');
                                                                    }
                                                                }
                                                                
                                                                checkboxes.forEach(cb => {
                                                                    cb.addEventListener('change', validateCheckboxGroup);
                                                                });
                                                                
                                                                // 表單提交時驗證
                                                                const form = document.getElementById('userForm');
                                                                if (form) {
                                                                    form.addEventListener('submit', function(e) {
                                                                        validateCheckboxGroup();
                                                                        if (!group.checkValidity()) {
                                                                            e.preventDefault();
                                                                            e.stopPropagation();
                                                                        }
                                                                    });
                                                                }
                                                            })();
                                                        </script>
                                                    <% } %>
                                                <% } else if (field.type === 'radio' && field.options) { %>
                                                    <div class="radio-group" id="<%= field.fieldName %>-group">
                                                        <% field.options.forEach((option, optionIndex) => { %>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" 
                                                                       id="<%= field.fieldName %>_<%= optionIndex %>" 
                                                                       name="<%= field.fieldName %>" 
                                                                       value="<%= option.value %>"
                                                                       data-zh="<%= option.label && option.label.zh ? option.label.zh : option.label %>" 
                                                                       data-en="<%= option.label && option.label.en ? option.label.en : '' %>"
                                                                       <%= field.required ? 'required' : '' %>>
                                                                <label class="form-check-label" for="<%= field.fieldName %>_<%= optionIndex %>"
                                                                       data-zh="<%= option.label && option.label.zh ? option.label.zh : (typeof option.label === 'string' ? option.label : '') %>" 
                                                                       data-en="<%= option.label && option.label.en ? option.label.en : '' %>">
                                                                    <%= option.label && option.label.zh ? option.label.zh : (typeof option.label === 'string' ? option.label : '') %>
                                                                </label>
                                                            </div>
                                                        <% }); %>
                                                    </div>
                                                <% } else if (field.type === 'textarea') { %>
                                                    <textarea class="form-control" id="<%= field.fieldName %>" name="<%= field.fieldName %>" 
                                                              placeholder="<%= field.placeholder && field.placeholder.zh ? field.placeholder.zh : (typeof field.placeholder === 'string' ? field.placeholder : '') %>" 
                                                              data-placeholder-zh="<%= field.placeholder && field.placeholder.zh ? field.placeholder.zh : '' %>" 
                                                              data-placeholder-en="<%= field.placeholder && field.placeholder.en ? field.placeholder.en : '' %>" 
                                                              <%= field.required ? 'required' : '' %> rows="3"></textarea>
                                                <% } else { %>
                                                    <input type="<%= field.type %>" class="form-control" id="<%= field.fieldName %>" name="<%= field.fieldName %>" 
                                                           placeholder="<%= field.placeholder && field.placeholder.zh ? field.placeholder.zh : (typeof field.placeholder === 'string' ? field.placeholder : '') %>" 
                                                           data-placeholder-zh="<%= field.placeholder && field.placeholder.zh ? field.placeholder.zh : '' %>" 
                                                           data-placeholder-en="<%= field.placeholder && field.placeholder.en ? field.placeholder.en : '' %>" 
                                                           <%= field.required ? 'required' : '' %>>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% } %>
                                <% }); %>
                            <% } %>
                        </div>
                    <% } %>
                <% }); %>
            <% } else { %>
                <!-- 預設表單結構（如果沒有配置） -->
                <div class="form-section">
                    <h3>聯絡人資料</h3>

                    <!-- 預設表單字段將在這裡顯示（如果沒有動態配置） -->
                    <div class="form-row">
                        <label class="form-label" for="email">
                            電子郵件 <span class="required">*</span>
                        </label>
                        <div class="form-input">
                            <input type="email" class="form-control" id="email" name="email" 
                                   placeholder="例如：peterwong@abccompany.com" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <label class="form-label" for="name">
                            姓名 <span class="required">*</span>
                        </label>
                        <div class="form-input">
                            <input type="text" class="form-control" id="name" name="name" 
                                   placeholder="例如：王小明" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <label class="form-label" for="company">
                            公司名稱 <span class="required">*</span>
                        </label>
                        <div class="form-input">
                            <input type="text" class="form-control" id="company" name="company" 
                                   placeholder="例如：ABC 公司" required>
                        </div>
                    </div>
                </div>
            <% } %>

            <!-- 票券選擇（如果適用） -->
            <% if (paymentTickets && paymentTickets.length > 0) { %>
                <div class="form-section">
                    <h3 class="section-title" data-zh="票券選擇" data-en="Ticket Selection">票券選擇</h3>
                    <div class="form-row">
                        <label class="form-label field-label" for="ticketId"
                               data-zh="選擇票券" data-en="Select Ticket">
                            選擇票券 <span class="required">*</span>
                        </label>
                        <div class="form-input">
                            <select class="form-control" id="ticketId" name="ticketId" required>
                                <option value="" data-zh="--- 請選擇票券 ---" data-en="--- Please select a ticket ---">--- 請選擇票券 ---</option>
                                <% paymentTickets.forEach(function(ticket) { 
                                    const now = new Date();
                                    const from = ticket.datetimeFrom ? new Date(ticket.datetimeFrom) : null;
                                    const to = ticket.datetimeTo ? new Date(ticket.datetimeTo) : (ticket.datetime ? new Date(ticket.datetime) : null);
                                    const inRange = (!from || now >= from) && (!to || now <= to);
                                    const tZh = (ticket.title && ticket.title.zh) ? ticket.title.zh : '';
                                    const tEn = (ticket.title && ticket.title.en) ? ticket.title.en : '';
                                    const optZh = tZh ? (tZh + ' - $' + ticket.price) : ('票券 - $' + ticket.price);
                                    const optEn = (tEn || tZh) ? ((tEn || tZh) + ' - $' + ticket.price) : ('Ticket - $' + ticket.price);
                                    if (inRange) { %>
                                        <option value="<%= ticket._id %>"
                                                data-zh="<%= optZh %>"
                                                data-en="<%= optEn %>"><%= optZh %></option>
                                <%  } 
                                }); %>
                            </select>
                        </div>
                    </div>
                </div>
            <% } %>

            <!-- Terms & Conditions（需同意才可提交） -->
            <% if (formConfig && formConfig.terms && formConfig.terms.enabled) { %>
                <div class="form-section terms-section">
                    <div class="terms-header">
                        <h3 class="section-title" data-zh="條款與細則" data-en="Terms & Conditions">條款與細則</h3>
                        <a href="#" class="terms-open-link lang-text" id="termsOpenLink" role="button"
                           data-zh="(條款)" data-en="(terms)">(terms)</a>
                    </div>
                    <div class="form-check terms-agree-row">
                        <input class="form-check-input" type="checkbox" id="termsAgree" required>
                        <label class="form-check-label"
                               for="termsAgree"
                               data-zh="<%= (formConfig.terms.label && formConfig.terms.label.zh ? formConfig.terms.label.zh : '') %>"
                               data-en="<%= (formConfig.terms.label && formConfig.terms.label.en ? formConfig.terms.label.en : '') %>"><%= (formConfig.terms.label && formConfig.terms.label.zh ? formConfig.terms.label.zh : '') %></label>
                    </div>
                </div>

                <div id="termsOverlay" class="terms-overlay" aria-hidden="true">
                    <div class="terms-modal" role="dialog" aria-modal="true" aria-labelledby="termsModalTitle">
                        <div class="terms-modal-header">
                            <h4 id="termsModalTitle" class="lang-text" data-zh="條款與細則" data-en="Terms & Conditions">Terms & Conditions</h4>
                            <button type="button" class="terms-modal-close" id="termsModalClose" aria-label="Close">&times;</button>
                        </div>
                        <div class="terms-modal-body" id="termsContent"></div>
                    </div>
                </div>
                <script type="application/json" id="termsContentJson"><%- JSON.stringify({
                    zh: (formConfig.terms.content && formConfig.terms.content.zh) ? formConfig.terms.content.zh : '',
                    en: (formConfig.terms.content && formConfig.terms.content.en) ? formConfig.terms.content.en : ''
                }) %></script>
            <% } %>

            <!-- Agreement（功能同 Terms & Conditions） -->
            <% if (formConfig && formConfig.agreement && formConfig.agreement.enabled) { %>
                <div class="form-section agreement-section">
                    <div class="terms-header">
                        <h3 class="section-title" data-zh="協議" data-en="Agreement">協議</h3>
                        <a href="#" class="terms-open-link lang-text" id="agreementOpenLink" role="button"
                           data-zh="(協議)" data-en="(agreement)">(agreement)</a>
                    </div>
                    <div class="form-check terms-agree-row">
                        <input class="form-check-input" type="checkbox" id="agreementAgree" required>
                        <label class="form-check-label"
                               for="agreementAgree"
                               data-zh="<%= (formConfig.agreement.label && formConfig.agreement.label.zh ? formConfig.agreement.label.zh : '') %>"
                               data-en="<%= (formConfig.agreement.label && formConfig.agreement.label.en ? formConfig.agreement.label.en : '') %>"><%= (formConfig.agreement.label && formConfig.agreement.label.zh ? formConfig.agreement.label.zh : '') %></label>
                    </div>
                </div>

                <div id="agreementOverlay" class="terms-overlay" aria-hidden="true">
                    <div class="terms-modal" role="dialog" aria-modal="true" aria-labelledby="agreementModalTitle">
                        <div class="terms-modal-header">
                            <h4 id="agreementModalTitle" class="lang-text" data-zh="協議" data-en="Agreement">Agreement</h4>
                            <button type="button" class="terms-modal-close" id="agreementModalClose" aria-label="Close">&times;</button>
                        </div>
                        <div class="terms-modal-body" id="agreementContent"></div>
                    </div>
                </div>
                <script type="application/json" id="agreementContentJson"><%- JSON.stringify({
                    zh: (formConfig.agreement.content && formConfig.agreement.content.zh) ? formConfig.agreement.content.zh : '',
                    en: (formConfig.agreement.content && formConfig.agreement.content.en) ? formConfig.agreement.content.en : ''
                }) %></script>
            <% } %>

            <div class="btn-container">
                <button type="button" class="btn btn-secondary lang-text" data-zh="返回" data-en="Back" onclick="history.back()">返回</button>
                <button type="submit" class="btn btn-primary lang-text" data-zh="下一步" data-en="Next">下一步</button>
            </div>
        </form>
        
        <div id="successMessage"></div>
        <div id="errorMessage"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script>
        // 從 URL 參數獲取語言
        function getLanguageFromURL() {
            const urlParams = new URLSearchParams(window.location.search);
            const lang = urlParams.get('lang');
            // 如果 URL 中有 lang 參數，且為 'zh' 或 'en'，則使用該語言
            if (lang === 'zh' || lang === 'en') {
                return lang;
            }
            return null;
        }
        
        // 語言設置：優先使用 URL 參數，否則使用默認語言
        const urlLanguage = getLanguageFromURL();
        let currentLanguage = urlLanguage || '<%= formConfig.defaultLanguage || "zh" %>';
        const formConfigEventName = <%- JSON.stringify(formConfig && formConfig.eventDisplayName ? formConfig.eventDisplayName : { zh: '', en: '' }) %>;
        const fallbackEventName = <%- JSON.stringify(event && event.name ? event.name : 'Event') %>;
        function getHeaderEventName(lang) {
            const zh = (formConfigEventName && formConfigEventName.zh) ? String(formConfigEventName.zh).trim() : '';
            const en = (formConfigEventName && formConfigEventName.en) ? String(formConfigEventName.en).trim() : '';
            if (lang === 'en') return en || zh || fallbackEventName;
            return zh || en || fallbackEventName;
        }
        const termsContentByLang = (function() {
            const el = document.getElementById('termsContentJson');
            if (!el) return { zh: '', en: '' };
            try { return JSON.parse(el.textContent); } catch (_) { return { zh: '', en: '' }; }
        })();
        const agreementContentByLang = (function() {
            const el = document.getElementById('agreementContentJson');
            if (!el) return { zh: '', en: '' };
            try { return JSON.parse(el.textContent); } catch (_) { return { zh: '', en: '' }; }
        })();

        /** 是否為區塊級 HTML（p/div/ul 等），此類內容直接渲染 */
        function termsLooksLikeBlockHtml(s) {
            return /<\s*\/?\s*(p|div|ul|ol|li|h[1-6]|table|tbody|tr|td|th|blockquote|section|article|br)\b/i.test(s);
        }

        /** 純文字或簡單 HTML：保留換行；完整 HTML 區塊則原樣輸出 */
        function formatTermsContent(raw) {
            const s = String(raw || '');
            if (!s.trim()) return '';
            if (termsLooksLikeBlockHtml(s)) {
                return s;
            }
            const normalized = s.replace(/\r\n/g, '\n');
            if (/<[a-z][\s\S]*?>/i.test(normalized)) {
                return normalized.replace(/\n/g, '<br>');
            }
            const div = document.createElement('div');
            div.textContent = normalized;
            return div.innerHTML.replace(/\n/g, '<br>');
        }

        function renderTermsContentHtml() {
            const $termsContent = $('#termsContent');
            if (!$termsContent.length) return;
            const raw = currentLanguage === 'en'
                ? (termsContentByLang.en || termsContentByLang.zh || '')
                : (termsContentByLang.zh || termsContentByLang.en || '');
            $termsContent.html(formatTermsContent(raw));
        }

        function renderAgreementContentHtml() {
            const $content = $('#agreementContent');
            if (!$content.length) return;
            const raw = currentLanguage === 'en'
                ? (agreementContentByLang.en || agreementContentByLang.zh || '')
                : (agreementContentByLang.zh || agreementContentByLang.en || '');
            $content.html(formatTermsContent(raw));
        }
        
        // 初始化語言按鈕狀態
        $(document).ready(function() {
            updateLanguageButtons();
            // 總是更新頁面語言（確保初始狀態正確）
            updatePageLanguage();
            
            // 頁面載入後，清除所有有效字段的驗證訊息
            setTimeout(function() {
                $('input[required], textarea[required], select[required]').each(function() {
                    const field = this;
                    const $field = $(field);
                    const fieldType = $field.attr('type');
                    
                    if (fieldType === 'checkbox' || fieldType === 'radio') {
                        return;
                    }
                    
                    // 如果字段有效，清除驗證訊息
                    if (field.validity.valid) {
                        field.setCustomValidity('');
                    }
                });
            }, 100);
        });

        // 切換語言
        function switchLanguage(lang) {
            currentLanguage = lang;
            updateLanguageButtons();
            updatePageLanguage();
            
            // 保存語言偏好到localStorage
            localStorage.setItem('preferredLanguage', lang);
        }

        // 更新語言按鈕狀態
        function updateLanguageButtons() {
            $('#langZhBtn').toggleClass('active', currentLanguage === 'zh');
            $('#langEnBtn').toggleClass('active', currentLanguage === 'en');
        }

        // 更新頁面語言
        function updatePageLanguage() {
            // 標題使用 FormConfig eventDisplayName（留空則 fallback event.name）
            $('#formTitle').text(getHeaderEventName(currentLanguage));
            if (currentLanguage === 'zh') {
                $('#formSubtitle').text('請填寫以下資料完成活動報名');
            } else {
                $('#formSubtitle').text('Please fill in the following information to complete event registration');
            }

            // 更新區塊標題
            $('.section-title').each(function() {
                const zhText = $(this).data('zh');
                const enText = $(this).data('en');
                if (currentLanguage === 'zh' && zhText) {
                    $(this).text(zhText);
                } else if (currentLanguage === 'en' && enText) {
                    $(this).text(enText);
                }
            });

            // 更新字段標籤
            $('.field-label').each(function() {
                const $label = $(this);
                const zhText = $label.data('zh');
                const enText = $label.data('en');
                // 檢查原始 HTML 中是否包含 required span，或檢查對應的輸入字段是否有 required 屬性
                const fieldId = $label.attr('for');
                const hasRequired = $label.find('.required').length > 0 || 
                                   (fieldId && $(`#${fieldId}`).attr('required') !== undefined);
                
                if (currentLanguage === 'zh' && zhText) {
                    if (hasRequired) {
                        $label.html(zhText + ' <span class="required">*</span>');
                    } else {
                        $label.text(zhText);
                    }
                } else if (currentLanguage === 'en' && enText) {
                    if (hasRequired) {
                        $label.html(enText + ' <span class="required">*</span>');
                    } else {
                        $label.text(enText);
                    }
                }
            });

            // 更新佔位符文本
            $('input, textarea').each(function() {
                const zhPlaceholder = $(this).data('placeholder-zh');
                const enPlaceholder = $(this).data('placeholder-en');
                if (currentLanguage === 'zh' && zhPlaceholder) {
                    $(this).attr('placeholder', zhPlaceholder);
                } else if (currentLanguage === 'en' && enPlaceholder) {
                    $(this).attr('placeholder', enPlaceholder);
                }
            });
            // select「其他」自填欄位佔位符
            $('.js-select-other-text').each(function() {
                const zhPlaceholder = $(this).data('placeholder-zh');
                const enPlaceholder = $(this).data('placeholder-en');
                if (currentLanguage === 'zh' && zhPlaceholder) {
                    $(this).attr('placeholder', zhPlaceholder);
                } else if (currentLanguage === 'en' && enPlaceholder) {
                    $(this).attr('placeholder', enPlaceholder);
                }
            });

            // 更新選擇框選項
            $('select option').each(function() {
                const zhText = $(this).data('zh');
                const enText = $(this).data('en');
                if (currentLanguage === 'zh' && zhText) {
                    $(this).text(zhText);
                } else if (currentLanguage === 'en' && enText) {
                    $(this).text(enText);
                }
            });

            // 更新 checkbox 和 radio 選項標籤
            $('.form-check-label').each(function() {
                const $label = $(this);
                const zhText = $label.data('zh');
                const enText = $label.data('en');
                if (currentLanguage === 'zh' && zhText) {
                    $label.text(zhText);
                } else if (currentLanguage === 'en' && enText) {
                    $label.text(enText);
                }
            });

            // 更新 T&C 內容（支援 HTML）
            renderTermsContentHtml();
            renderAgreementContentHtml();

            // 更新按鈕文字（返回、下一步等）
            $('.lang-text').each(function() {
                const zhText = $(this).data('zh');
                const enText = $(this).data('en');
                if (currentLanguage === 'zh' && zhText) {
                    $(this).text(zhText);
                } else if (currentLanguage === 'en' && enText) {
                    $(this).text(enText);
                }
            });

            // 設置驗證訊息的函數（只在驗證失敗時調用）
            function setValidationMessage(field) {
                const $field = $(field);
                const fieldType = $field.attr('type');
                
                // 如果是 checkbox 或 radio，跳過（它們有特殊的驗證邏輯）
                if (fieldType === 'checkbox' || fieldType === 'radio') {
                    return;
                }
                
                // 根據語言設置驗證訊息
                if (currentLanguage === 'zh') {
                    if (field.validity.valueMissing) {
                        field.setCustomValidity('請填寫這個欄位。');
                    } else if (fieldType === 'email' && field.validity.typeMismatch) {
                        field.setCustomValidity('請輸入有效的電子郵件地址。');
                    } else {
                        field.setCustomValidity('請填寫這個欄位。');
                    }
                } else {
                    if (field.validity.valueMissing) {
                        field.setCustomValidity('Please fill in this field.');
                    } else if (fieldType === 'email' && field.validity.typeMismatch) {
                        field.setCustomValidity('Please enter a valid email address.');
                    } else {
                        field.setCustomValidity('Please fill in this field.');
                    }
                }
            }

            // 為所有必填字段設置驗證訊息處理
            $('input[required], textarea[required], select[required]').each(function() {
                const field = this;
                const $field = $(field);
                const fieldType = $field.attr('type');
                
                // 跳過 checkbox 和 radio（它們有特殊的驗證邏輯）
                if (fieldType === 'checkbox' || fieldType === 'radio') {
                    return;
                }
                
                // 監聽輸入事件，清除驗證訊息（如果字段有效）
                $(field).on('input', function() {
                    // 立即清除驗證訊息，讓瀏覽器重新驗證
                    this.setCustomValidity('');
                    // 如果字段有效，確保保持清除狀態
                    if (this.validity.valid) {
                        this.setCustomValidity('');
                    }
                });
                
                // 監聽改變事件，清除驗證訊息（如果字段有效）
                $(field).on('change', function() {
                    // 立即清除驗證訊息
                    this.setCustomValidity('');
                    if (this.validity.valid) {
                        this.setCustomValidity('');
                    }
                });
                
                // 在驗證失敗時設置訊息
                $(field).on('invalid', function(e) {
                    // 只在字段確實無效時設置訊息
                    if (!this.validity.valid) {
                        setValidationMessage(this);
                    }
                });
            });
            
            // 在語言切換後，更新所有字段的驗證訊息（只在字段無效時）
            const originalUpdatePageLanguage = updatePageLanguage;
            updatePageLanguage = function() {
                originalUpdatePageLanguage.call(this);
                
                // 更新所有無效字段的驗證訊息（只在字段已經有自定義驗證訊息時才更新）
                $('input[required], textarea[required], select[required]').each(function() {
                    const field = this;
                    const $field = $(field);
                    const fieldType = $field.attr('type');
                    
                    if (fieldType === 'checkbox' || fieldType === 'radio') {
                        return;
                    }
                    
                    // 如果字段有效，清除所有驗證訊息
                    if (field.validity.valid) {
                        field.setCustomValidity('');
                    } else {
                        // 只有當字段確實無效且已經有驗證訊息時才更新（避免在頁面載入時設置）
                        // 檢查字段是否有值，如果有值但無效，才更新訊息
                        if (field.value && field.value.trim() !== '') {
                            // 字段有值但驗證失敗（如 email 格式錯誤），更新訊息
                            setValidationMessage(field);
                        } else {
                            // 字段為空，但只在已經觸發過驗證時才設置訊息
                            // 這裡不設置，讓瀏覽器在實際驗證時才設置
                        }
                    }
                });
            };

        }

        function initOverlayAndValidation(opts) {
            const overlay = document.getElementById(opts.overlayId);
            const openLink = document.getElementById(opts.openLinkId);
            const closeBtn = document.getElementById(opts.closeBtnId);
            const agreeEl = document.getElementById(opts.agreeId);

            function openOverlay(e) {
                if (e) e.preventDefault();
                if (!overlay) return;
                overlay.classList.add('is-open');
                overlay.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            }

            function closeOverlay() {
                if (!overlay) return;
                overlay.classList.remove('is-open');
                overlay.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            }

            if (openLink) openLink.addEventListener('click', openOverlay);
            if (closeBtn) closeBtn.addEventListener('click', closeOverlay);
            if (overlay) {
                overlay.addEventListener('click', function(e) {
                    if (e.target === overlay) closeOverlay();
                });
            }
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && overlay && overlay.classList.contains('is-open')) {
                    closeOverlay();
                }
            });

            if (agreeEl) {
                agreeEl.addEventListener('change', function() {
                    this.setCustomValidity('');
                });
                agreeEl.addEventListener('invalid', function() {
                    const msg = currentLanguage === 'zh'
                        ? (opts.invalidMsgZh || '請先閱讀並勾選同意，才可提交。')
                        : (opts.invalidMsgEn || 'Please agree before submitting.');
                    this.setCustomValidity(msg);
                });
            }
        }

        // Terms & Conditions
        initOverlayAndValidation({
            overlayId: 'termsOverlay',
            openLinkId: 'termsOpenLink',
            closeBtnId: 'termsModalClose',
            agreeId: 'termsAgree',
            invalidMsgZh: '請先閱讀並勾選同意條款，才可提交。',
            invalidMsgEn: 'Please agree to the terms before submitting.'
        });

        // Agreement
        initOverlayAndValidation({
            overlayId: 'agreementOverlay',
            openLinkId: 'agreementOpenLink',
            closeBtnId: 'agreementModalClose',
            agreeId: 'agreementAgree',
            invalidMsgZh: '請先閱讀並勾選同意協議，才可提交。',
            invalidMsgEn: 'Please agree to the agreement before submitting.'
        });

        // stripe public key
        const STRIPE_PK = '<%= process.env.STRIPE_PK || "" %>';
        let stripe;
        if (STRIPE_PK) {
            stripe = Stripe(STRIPE_PK);
        }

        // FormConfig：select 勾選「其他可自填」時，以隱藏欄位送出用戶輸入文字
        function syncSelectWithOther(selectEl) {
            if (!selectEl || !selectEl.getAttribute('data-select-other-base')) return;
            var base = selectEl.getAttribute('data-select-other-base');
            var hidden = document.getElementById(base + '_hidden');
            var other = document.getElementById(base + '_other');
            if (!hidden || !other) return;
            var opt = selectEl.options[selectEl.selectedIndex];
            var isOther = opt && opt.getAttribute('data-is-other') === '1';
            if (isOther) {
                $(other).removeClass('d-none');
                if (selectEl.hasAttribute('required')) {
                    other.setAttribute('required', 'required');
                } else {
                    other.removeAttribute('required');
                }
                hidden.value = (other.value || '').trim();
            } else {
                $(other).addClass('d-none');
                other.removeAttribute('required');
                other.value = '';
                other.setCustomValidity('');
                hidden.value = selectEl.value || '';
            }
        }
        $(document).on('change', '.js-select-maybe-other', function() {
            syncSelectWithOther(this);
        });
        $(document).on('input', '.js-select-other-text', function() {
            var id = this.id;
            if (id && id.indexOf('_other') !== -1) {
                var base = id.replace(/_other$/, '');
                var sel = document.getElementById(base + '_sel');
                if (sel) syncSelectWithOther(sel);
            }
        });
        $(function() {
            $('.js-select-maybe-other').each(function() { syncSelectWithOther(this); });
        });

        $('#userForm').on('submit', function(e) {
            e.preventDefault(); // 防止表單默認提交
            $('.js-select-maybe-other').each(function() { syncSelectWithOther(this); });
            var formEl = document.getElementById('userForm');
            $('.js-select-other-text').each(function() {
                if (!$(this).hasClass('d-none') && this.hasAttribute('required') && !((this.value || '').trim())) {
                    this.setCustomValidity(currentLanguage === 'zh' ? '請填寫這個欄位。' : 'Please fill in this field.');
                } else {
                    this.setCustomValidity('');
                }
            });
            if (formEl && !formEl.checkValidity()) {
                formEl.reportValidity();
                return;
            }
            const ticketId = $('#ticketId').val();
            
            // 動態收集所有表單字段
            const newUser = {};
            $('#userForm').find('input, select, textarea').each(function() {
                const fieldName = $(this).attr('name');
                if (fieldName && fieldName !== 'ticketId') {
                    newUser[fieldName] = $(this).val();
                }
            });
            newUser.ticketId = ticketId;
            if (ticketId) {
                // Wonder Payment checkout（沿用舊 API 路徑）

                newUser.lang = currentLanguage;
                
                $.ajax({
                    type: 'POST',
                    url: '/web/<%= event_id %>/stripe-checkout',
                    contentType: 'application/json',
                    data: JSON.stringify(newUser),
                    success: function(response) {
                        if (response.url) {
                            window.location.href = response.url;
                        } else {
                            $('#errorMessage').html('<div class="alert alert-danger">無法跳轉到付款頁面</div>');
                        }
                    },
                    error: function(error) {
                        var errMsg = error.responseJSON && error.responseJSON.message ? error.responseJSON.message : '付款失敗';
                        $('#errorMessage').html('<div class="alert alert-danger">'+errMsg+'</div>');
                    }
                });
            } else {
                // 無票券，直接註冊
                $.ajax({
                    type: 'POST',
                    url: '/events/<%= event_id %>/users',
                    data: newUser,
                    success: function(response) {
                        const langParam = currentLanguage !== 'zh' ? '?lang=' + currentLanguage : '';
                        window.location.href = `/web/<%= event_id %>/register/success${langParam}`;
                    },
                    error: function(error) {
                        var errMsg = error.responseJSON.message;
                        $('#errorMessage').html('<div class="alert alert-danger">登記失敗！'+errMsg+'</div>');
                        $('#successMessage').html('');
                    }
                });
            }
        });
    </script>
</body>
</html>