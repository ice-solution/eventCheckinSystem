<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>報名已關閉 - <%= event ? event.name : 'Event' %></title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-bottom: 40px;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 15px;
        }
        .closed-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            padding: 40px;
            text-align: center;
            margin-top: 30px;
            margin-bottom: 30px;
        }
        .closed-title {
            color: #495057;
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .closed-subtitle {
            color: #6c757d;
            font-size: 1rem;
            margin-bottom: 24px;
        }
        .closed-message {
            background: #f1f3f5;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 24px;
            text-align: left;
            white-space: pre-wrap;
            word-break: break-word;
            color: #212529;
            font-size: 1rem;
            line-height: 1.6;
        }
        .carousel-item img {
            width: 100%;
            height: auto;
            object-fit: cover;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Banner（與 register 頁相同） -->
        <div id="carouselExampleCaptions" class="carousel slide" data-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="/exvent/<%= event_id %>.jpg" class="d-block w-100" alt="Banner" 
                         onerror="this.src='/exvent/banner.jpg'">
                    <div class="carousel-caption d-none d-md-block"></div>
                </div>
            </div>
        </div>

        <div class="closed-container">
            <h1 class="closed-title"><%= event ? event.name : 'Event' %></h1>
            <p class="closed-subtitle">報名已關閉 / Registration is closed</p>
            <div class="closed-message"><%= typeof message === 'string' ? message : 'Registration is currently closed.' %></div>
        </div>
    </div>
</body>
</html>
